@model PhotoByIdDTO

@{
    ViewData["Title"] = Model?.Photo?.Name;
}

<div class="container mt-5 py-5">
    <div class="row py-4">
        @if (User.IsInRole("Administrator"))
        {
            <div class="col-12 col-md-6 col-lg-2">
                <form asp-controller="Photo" asp-action="ChangeDownloadPermissions" method="POST">
                    <input type="hidden" asp-for="Photo.Id" />
                    <button type="submit" class="btn btn-warning text-white">@(Model.Photo.IsDownloadable ? "Non-downloadble" : "Downloadable")</button>
                </form>
            </div>
            <div class="col-12 col-md-6 col-lg-2">
                <form asp-controller="Photo" asp-action="Delete" method="POST">
                    <input type="hidden" asp-for="Photo.Id" />
                    <input type="hidden" asp-for="Photo.Name" />
                    <button type="submit" class="btn btn-danger text-white">Delete</button>
                </form>
            </div>
        }
    </div>
    <div class="row">
        <div class="col-12 col-image text-center mx-auto">
            <img src="~/resources/gallery-photos/@(PhotoSize.Small.ToString() + "_" + Model?.Photo?.FileName)" />
        </div>
    </div>
    <div class="row mt-3">
        <div class="col-12 col-md-6 col-lg-8">
            <h1>@Model?.Photo?.Name</h1>
            <p class="photo-description">@Model?.Photo?.Description</p>
        </div>
        <div class="col-12 col-md-6 col-lg-4 col-details">
            <form asp-controller="Order" asp-action="OrderInfo" method="GET" enctype="multipart/form-data">
                <input type="hidden" asp-for="Photo.Id" />
                <input type="hidden" asp-for="Photo.FileData" />
                <input type="hidden" asp-for="Photo.FileName" />
                <input type="hidden" asp-for="Photo.FileType" />
                <input type="hidden" asp-for="Photo.Name" />
                <input type="hidden" asp-for="Photo.IsFree" />
                
                @if (Model.Photo.IsDownloadable && !Model.Photo.IsFree)
                {
                    <h3 id="price-text-wrapper"></h3>
                }
                 <select asp-for="PhotoSize" asp-items="Html.GetEnumSelectList<PhotoSize>()" class="form-control"></select>
                   
                    @if (Model.Photo.IsFree)
                    {
                        <button class="btn btn-primary btn-lg btn-download" type="submit"><i class="fa-solid fa-download"></i></button>
                    }

                    else
                    {
                        <input type="hidden" asp-for="Photo.Price" />
                        <button class="btn btn-primary btn-lg btn-download" type="submit"><i class="fa-solid fa-download"></i></button>
                    }
               
            </form>
        </div>
    </div>
    <div class="row mt-5">
        <div class="col-3 photo-details-container">
            <div class="icon mx-auto text-center">
                <span><i class="fa-solid fa-location-dot fa-2x"></i></span>
            </div>
            <div class="photo-details-item text-center mx-auto mt-3">
                <span class="details-text" id="location">@Model.Photo.GeoLocation</span>
            </div>
        </div>
        <div class="col-3 photo-details-container">
            <div class="icon mx-auto text-center">
                <span><i class="fa-solid fa-camera-retro fa-2x"></i></span>
            </div>
            <div class="photo-details-item text-center mx-auto mt-3">
                <span class="details-text" id="gear">@Model?.Photo?.Gear?.CameraBrand @Model?.Photo?.Gear?.CameraModel, @Model?.Photo?.Gear?.CameraLens, @Model?.Photo?.Gear?.AdditionalInformation</span>
            </div>
        </div>
        <div class="col-3 photo-details-container">
            <div class="icon mx-auto text-center">
                <span><i class="fa-solid fa-hashtag fa-2x"></i></span>
            </div>
            <div class="photo-details-item text-center mx-auto mt-3">
                
                @foreach (Tag tag in Model.Photo.Tags)
                {
                    <span class="details-text tags-text" id="tags"><a asp-controller="Photo" asp-action="AllByTag" asp-route-tag="@tag.Text">#@tag.Text</a></span>
                }
            </div>
        </div>
        <div class="col-3 photo-details-container">
            <div class="icon mx-auto text-center">
                <span><i class="fa-solid fa-layer-group fa-2x"></i></span>
            </div>
            <div class="photo-details-item text-center mx-auto mt-3">
                
                @foreach (PhotoCategory photoCategory in Model.Photo.PhotoCategories)
                {
                    <span class="details-text featured-in-text" id="featured-in">
                        <a asp-controller="Photo" asp-action="AllByCategory" asp-route-category="@photoCategory.Category">@(photoCategory.Category.GetAttribute<DisplayAttribute>().Name)</a>
                    </span>
                }
            </div>
        </div>
    </div>
</div>

<style>
    

    .container .row .col-image img{
        width: 100%;
    }

    .container .row .col-details{
        padding-top: 30px;
    }

    .container .row .col-details h1{
        text-align: center;
    }

    .container .row .col-details .photo-description{
        margin-top: 40px;
    }

    .container .row .col-details #price{
      margin-top: 20px;
    }

    .container .row .col-details select{
      margin-top: 30px;
      height: 50px;
    }

    .container .row .col-details .btn-download{
        width: 100%;
        margin-top: 20px;
        color: #fff;
    }

    .tags-text, .featured-in-text {
        line-height: 10px;
    }
</style>

<script>

    $(document).ready(function(){

        //calculate price on page load
        calculatePrice();

        //calculate price when different size is selected
        $("#PhotoSize").change(function(){
            calculatePrice();
        });
    });

    function calculatePrice(){
        let priceValue = @(Model?.Photo?.Price?.ToString(CultureInfo.InvariantCulture));
        let priceCalculated = $("#price-text-wrapper");
        let price = $("#Photo_Price");
        let size = $("#PhotoSize").find(":selected");
        switch (size.val()) {
            case "@((int)PhotoSize.Small)": {
                price.val((parseInt(priceValue) - (parseInt(priceValue) * 0.8)).toFixed(2));
                priceCalculated.html(price.val() + "лв");
                break;
            }
            case "@((int)PhotoSize.Medium)": {
                price.val((parseInt(priceValue) - (parseInt(priceValue) * 0.5)).toFixed(2));
                priceCalculated.html(price.val() + "лв");
                break;
            }
            case "@((int)PhotoSize.Large)": {
                price.val((parseInt(priceValue) - (parseInt(priceValue) * 0.2)).toFixed(2));
                priceCalculated.html(price.val() + "лв");
                break;
            }
            default: {
                price.val(parseInt(priceValue).toFixed(2));
                priceCalculated.html(price.val() + "лв");
                break;
            }
        }
    }

</script>