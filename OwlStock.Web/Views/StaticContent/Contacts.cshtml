<!-- Contact Start -->
<div class="container-xxl pb-5">
    <div class="container">
        <div class="text-center mx-auto wow fadeInUp" data-wow-delay="0.1s" style="max-width: 500px;">
            <h1 class="display-2"><i class="fa-solid fa-address-card text-primary mb-3"></i></h1>
            <h1 class="display-6 mb-2">ВРЪЗКА С НАС</h1>
            <p class="text-primary text-uppercase mb-2">Опитваме се да отговаряме на всички Ваши запитвания в най-кратък срок</p>
        </div>
        <div class="row g-3 mt-5">
            <div class="col-lg-4 col-md-6 pt-lg-5 wow fadeInUp" data-wow-delay="0.1s">
                <div class="fact-item bg-light text-center h-100 p-5">
                    <h1 class="text-primary display-2 mb-3">
                        <a class="rounded-circle px-2 me-2 social-contacts" href="#"><i style="color:#365a99" class="fab fa-facebook-f"></i></a>
                        <a class="rounded-circle px-2 me-2 social-contacts" href="#"><i style="color:#dd2a7b" class="fab fa-instagram"></i></a>
                        <a class="rounded-circle px-2 me-2 social-contacts" href="#"><i style="color:#0072B1" class="fab fa-linkedin-in"></i></a>
                    </h1>
                    <h4 class="mb-3">Последвайте ни</h4>
                    <span>Може да ни пишете по всяко време, удобно за вас</span>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.3s">
                <div class="fact-item bg-light text-center h-100 p-5">
                    <h1 class="display-2 text-primary mb-3"><i class="fa fa-phone-alt me-2"></i></h1>
                    <h4 class="mb-3">+359 878 131828</h4>
                    <span>Може да се свържете с нас всеки ден от 9:00 до 18:00 ч</span>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 pt-lg-5 wow fadeInUp" data-wow-delay="0.5s">
                <div class="fact-item bg-light text-center h-100 p-5">
                    <h1 class="display-2 text-primary mb-3"><i class="fa fa-envelope me-2"></i></h1>
                    <h4 class="mb-3">photonic@gmail.com</h4>
                    <span>Ще отговорим във възможно най-кратък срок</span>
                </div>
            </div>
        </div>
    </div>
    <div class="container mt-5">
        <div class="text-center mx-auto wow fadeInUp" data-wow-delay="0.1s" style="max-width: 500px;">
            <p class="text-primary text-uppercase mb-2">Запитване</p>
            <h1 class="display-6 mb-5">Изпратете ни запитване по всяко време</h1>
        </div>
        <div class="row g-0 justify-content-center">
            <div class="col-lg-8 wow fadeInUp" data-wow-delay="0.1s">
                <p class="text-center mb-4">Може да ни зададете всякакви въпроси по всяко време. Стараем се да отговорим на всеки един от тях възможно най-скоро.</p>
                <div asp-validation-summary="All" class="text-danger"></div>
                <form asp-action="SendInquiry" asp-controller="Inquiry" method="POST" id="contactForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ReCaptchaToken" id="recaptchaTokenInputId" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" class="form-control" asp-for="Name" placeholder="Име">
                                <label for="name">Име</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="email" class="form-control" asp-for="From" placeholder="Имейл">
                                <label for="email">Имейл</label>
                                <span class="text-danger" id="email-error-message" style="display:none">Въведете валиден имейл</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-floating">
                                <input type="text" class="form-control" asp-for="Topic" placeholder="Тема">
                                <label for="subject">Тема</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-floating">
                                <textarea class="form-control" placeholder="Вашето запитване" asp-for="Content" style="height: 200px"></textarea>
                                <label for="message">Вашето запитване</label>
                            </div>
                        </div>
                        <div class="col-12 text-center">
                            <div class="form-floating text-center">
                                <div class="text-center" id="recaptcha-container" data-callback="onSubmit"></div>
                            </div>
                        </div>
                        <div class="col-12 text-center">
                            <button class="btn btn-primary py-3 px-5 btn-submit" type="submit">Изпрати</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<!-- Contact End -->

<style>
    .social-contacts{
        font-size: unset;
        transition: .3s ease-in-out;
    }
    .social-contacts:hover{
        font-size: 3.5rem;
        transition: .2s ease-in-out;
    }
</style>

<script src="https://www.google.com/recaptcha/api.js"></script>
<script src="~/js/custom//recaptcha.js" data-siteKey="@siteKey"></script>
<script src="https://www.google.com/recaptcha/api.js?onload=onloadCallback&render=explicit" async defer> </script>

<script>
    $(document).ready(function () {
        $(".btn-submit").click(function (event) {
            event.preventDefault();

            //validate on each submit
            validateName();
            validateEmail();
            validateTopic();
            validateContent();

            //submit the form if all of the form inputs are valid
            if (validateName() && validateEmail() && validateTopic() && validateContent()) {
                $("#contactForm").submit();
            }
        });


        //check for changes in inputs
        $("#Name").change(function () {
            validateName();
        });

        $("#From").change(function () {
            validateEmail();
        });

        $("#Topic").change(function () {
            validateTopic();
        });

        $("#Content").change(function () {
            validateContent();
        });
    });


    //validate inputs
    function validateName() {
        if ($("#Name").val() == "" || $("#Name").val() == null) {
            $("#Name").addClass("border border-danger");
            return false;
        }

        else {
            $("#Name").removeClass("border border-danger");
            $(".btn-submit").prop('disabled', false);
            return true;
        }
    }


    function validateEmail() {
        if ($("#From").val() == "" || $("#From").val() == null) {
            $("#From").addClass("border border-danger");
            return false;
        }

        else {
            const email = $('#From').val();
            const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
            if (!emailRegex.test(email)) {
                $('#email-error-message').css("display", "block");
                return false;
            }

            else {
                $('#email-error-message').css("display", "none");
                return true;
            }

            $("#From").removeClass("border border-danger");
            return true;
        }
    }

    function validateTopic() {
        if ($("#Topic").val() == "" || $("#Topic").val() == null) {
            $("#Topic").addClass("border border-danger");
            return false;
        }

        else {
            $("#Topic").removeClass("border border-danger");
            return true;
        }
    }

    function validateContent() {
        if ($("#Content").val() == "" || $("#Content").val() == null) {
            $("#Content").addClass("border border-danger");
            return false;
        }

        else {
            $("#Content").removeClass("border border-danger");
            return true;
        }
    }
</script>
