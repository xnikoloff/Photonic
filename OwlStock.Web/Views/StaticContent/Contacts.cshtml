@{
    ViewData["Title"] = "Контакти";
}

<!--================Breadcrumb Area =================-->
<section class="breadcrumb_area">
    <div class="overlay bg-parallax" data-stellar-ratio="0.8" data-stellar-vertical-offset="0" data-background=""></div>
    <div class="container">
        <div class="page-cover text-center">
            <h2 class="page-cover-tittle">Контакти</h2>
            <ol class="breadcrumb">
                <li><a href="index.html">Начало</a></li>
                <li class="active">Контакти</li>
            </ol>
        </div>
    </div>
</section>
<!--================Breadcrumb Area =================-->
<!--================Contact Area =================-->
<section class="contact_area section_gap">
    <div class="container">
        <!--<div id="mapBox" class="mapBox"
             data-lat="40.701083"
             data-lon="-74.1522848"
             data-zoom="13"
             data-info="PO Box CT16122 Collins Street West, Victoria 8007, Australia."
             data-mlat="40.701083"
             data-mlon="-74.1522848">
        </div>-->
        <div class="row">
            <div class="col-md-3">
                <div class="contact_info">
                    <div class="info_item">
                        <i class="lnr lnr-home"></i>
                        <h6>Асеновград, България</h6>
                    </div>
                    <div class="info_item mt-3">
                        <i class="lnr lnr-phone-handset"></i>
                        <h6><a href="#">+359 878 131828</a></h6>
                        <p>Може да се свържете с нас всеки ден от 9:00 до 18:00 ч</p>
                    </div>
                    <div class="info_item">
                        <i class="lnr lnr-envelope"></i>
                        <h6><a href="#">photonic@gmail.com</a></h6>
                        <p>Изпратете ни запитване по всяко време</p>
                    </div>
                </div>
            </div>
            <div class="col-md-9">
                <form class="row contact_form" asp-action="SendEmailQuery" asp-controller="Query" method="post" id="contactForm" novalidate="novalidate">
                    <div class="col-md-6">
                        <div class="form-group">
                            <input type="text" class="form-control" id="name" name="name" placeholder="Име">
                        </div>
                        <div class="form-group">
                            <input type="email" class="form-control" id="email" name="email" placeholder="Имейл">
                        </div>
                        <div class="form-group">
                            <input type="text" class="form-control" id="subject" name="subject" placeholder="Тема">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <textarea class="form-control" name="message" id="message" rows="1" placeholder="Съобщение"></textarea>
                        </div>
                    </div>
                    <div class="col-md-12 text-right">
                        <button type="submit" value="submit" class="btn theme_btn button_hover">Изпращане</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
<!--================Contact Area =================-->
