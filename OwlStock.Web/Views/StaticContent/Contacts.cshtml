@model SendInquiryEmailTemplateDTO

@{
    ViewData["Title"] = "Контакти";
}

<!--================Breadcrumb Area =================-->
<section class="breadcrumb_area">
    <div class="overlay bg-parallax" data-stellar-ratio="0.8" data-stellar-vertical-offset="0" data-background=""></div>
    <div class="container">
        <div class="page-cover text-center">
            <h2 class="page-cover-tittle">Контакти</h2>
            <ol class="breadcrumb">
                <li><a href="index.html">Начало</a></li>
                <li class="active">Контакти</li>
            </ol>
        </div>
    </div>
</section>
<!--================Breadcrumb Area =================-->
<!--================Contact Area =================-->
<section class="contact_area section_gap">
    <div class="container">
        <!--<div id="mapBox" class="mapBox"
             data-lat="40.701083"
             data-lon="-74.1522848"
             data-zoom="13"
             data-info="PO Box CT16122 Collins Street West, Victoria 8007, Australia."
             data-mlat="40.701083"
             data-mlon="-74.1522848">
        </div>-->
        <div class="row">
            <div class="col-md-3">
                <div class="contact_info">
                    <div class="info_item">
                        <i class="lnr lnr-home"></i>
                        <h6>Асеновград, България</h6>
                    </div>
                    <div class="info_item mt-3">
                        <i class="lnr lnr-phone-handset"></i>
                        <h6><a href="#">+359 878 131828</a></h6>
                        <p>Може да се свържете с нас всеки ден от 9:00 до 18:00 ч</p>
                    </div>
                    <div class="info_item">
                        <i class="lnr lnr-envelope"></i>
                        <h6><a href="#">photonic@gmail.com</a></h6>
                        <p>Изпратете ни запитване по всяко време</p>
                    </div>
                </div>
            </div>
            <div class="col-md-9">
                <div asp-validation-summary="All" class="text-danger"></div>
                <form class="row contact_form" asp-action="SendInquiry" asp-controller="Inquiry" method="POST" id="contactForm">
                    <div class="col-md-6">
                        <div class="form-group">
                            <input type="text" class="form-control" asp-for="Name" placeholder="Име">
                        </div>
                        <div class="form-group">
                            <input type="email" class="form-control" asp-for="From" placeholder="Имейл">
                        </div>
                        <div class="form-group">
                            <input type="text" class="form-control" asp-for="Topic" placeholder="Тема">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <textarea class="form-control" asp-for="Content" rows="1" placeholder="Съобщение"></textarea>
                        </div>
                    </div>
                    <div class="col-md-12 text-right">
                        <button type="submit" value="submit" class="btn theme_btn button_hover btn-submit">Изпращане</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
<!--================Contact Area =================-->

<script>
    $(document).ready(function () {
        $(".btn-submit").click(function (event) {
            event.preventDefault();

            //validate on each submit
            validateName();
            validateEmail();
            validateTopic();
            validateContent();

            //submit the form if all of the form inputs are valid
            if (validateName() && validateEmail() && validateTopic() && validateContent()) {
                $("#contactForm").submit();
            }
        });


        //check for changes in inputs
        $("#Name").change(function () {
            validateName();
        });

        $("#From").change(function () {
            validateEmail();
        });

        $("#Topic").change(function () {
            validateTopic();
        });

        $("#Content").change(function () {
            validateContent();
        });
    });


    //validate inputs
    function validateName() {
        if ($("#Name").val() == "" || $("#Name").val() == null) {
            $("#Name").addClass("border border-danger");
            return false;
        }

        else {
            $("#Name").removeClass("border border-danger");
            $(".btn-submit").prop('disabled', false);
            return true;
        }
    }


    function validateEmail() {
        if ($("#From").val() == "" || $("#From").val() == null) {
            $("#From").addClass("border border-danger");
            return false;
        }

        else {
            $("#From").removeClass("border border-danger");
            return true;
        }
    }

    function validateTopic() {
        if ($("#Topic").val() == "" || $("#Topic").val() == null) {
            $("#Topic").addClass("border border-danger");
            return false;
        }

        else {
            $("#Topic").removeClass("border border-danger");
            return true;
        }
    }

    function validateContent() {
        if ($("#Content").val() == "" || $("#Content").val() == null) {
            $("#Content").addClass("border border-danger");
            return false;
        }

        else {
            $("#Content").removeClass("border border-danger");
            return true;
        }
    }
</script>
