@{
    ViewData["Title"] = "Сватбена фотография в Пловдив | Сватбени портрети | Заснемане на сватбени ритуали в Пловдив и страната";
}

<!-- Page Header Start -->
<div class="container-fluid page-header-wedding py-5 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container py-5">
        <h1 class="display-1 text-white animated slideInDown">Сватбена фотография</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb text-uppercase mb-0">
                <li class="breadcrumb-item"><a class="text-white" asp-controller="Home" asp-action="Index">Начало</a></li>
                <li class="breadcrumb-item text-primary active" aria-current="page">Сватбена фотография</li>
            </ol>
        </nav>
    </div>
</div>
<!-- Page Header End -->
<!-- Feature Business Photography Start -->
<div class="container-xxl py-5 mt-5">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-6 wow fadeInUp" data-wow-delay="0.5s">
                <div class="feature-img">
                    <img class="img-fluid" src="~/img/svatbena-fotografiya-1.jpg" alt="about3" style="max-height:650px">
                        <img class="img-fluid" src="~/img/svatbena-fotografiya-2.jpg" alt="about3" style="max-height:650px">
                </div>
            </div>
            <div class="col-lg-6 wow fadeInUp" data-wow-delay="0.1s">
                <h2 class="section-title">Сватбена <span class="text-dark">фотография</span></h2>
                <!--<h1 class="display-5 mb-4">Целта ни е </h1>-->
                <div class="row mt-5 g-4">
                    <div class="col-12">
                        <div class="d-flex align-items-start">
                            <h1><i class="fa-solid fa-champagne-glasses text-primary"></i></h1>
                            <div class="ms-4">
                                <h3>Вашата сватба през нашия обектив</h3>
                                <p class="mb-3">Погледът преди церемонията, ръцете, които се стискат малко по-силно, сълзите на близките, смехът с приятели – това са истинските спомени, които остават. Нашата цел е да уловим красотата на сватбения ден така, че когато разглеждате снимките след години, да усещате същата емоция.</p>
                                <p class="mb-0">Във ФОТОНИК предлагаме сватбена фотография в Пловдив и цяла България, улавяйки всяка история такава, каквато е – истинска и незабравима.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="d-flex align-items-start">
                            <h1><i class="fa-solid fa-heart text-primary"></i></h1>
                            <div class="ms-4">
                                <h3>Сватбени портрети</h3>
                                <p class="mb-3">Във ФОТОНИК истински ценим тишината между големите събития, усмивките, които не са режисирани, и докосванията, в които любовта, близостта и семейните връзки заемат главната роля.</p>
                                <p class="mb-0">Сватбените портрети улавят красотата, нежността и неподправените емоции между младоженците, когато те могат да бъдат себе си, далеч от напрежението и динамиката на целия ден. За нас снимката не е просто документ от сватбения ден, а спомен, който остава жив и топъл завинаги.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="container container-wedding-prices packet mt-5 pt-5">
            <div class="row">
                <div class="col-12">
                    <h1 class="section-title"><span class="text-dark">Пакети</span> Сватбa</h1>
                    <hr />
                </div>
            </div>
            <div class="row mt-3">
                <div class="col-6 col-md-3">
                    <div class="card card-packet">
                        <div class="card-header text-center">
                            <h3>Стандартен</h3>
                        </div>
                        <div class="card-body text-center">
                            <h2 class="service-price">@DefaultValue.WeddingPhotoshoot лв</h2>
                            <hr />
                            <h5>@DefaultValue.WeddingPhotoshootDescription</h5>
                        </div>
                        <div class="card-footer text-center">
                            <a asp-controller="Photoshoot" asp-action="ReserveByType" asp-route-photoshootType="@PhotoShootType.Wedding" class="btn btn-primary">РЕЗЕРВИРАЙ</a>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card card-packet">
                        <div class="card-header text-center">
                            <h3>Плюс</h3>
                        </div>
                        <div class="card-body text-center">
                            <h2 class="service-price">@DefaultValue.WeddingPlusPhotoshoot лв</h2>
                            <hr />
                            <h5>@DefaultValue.WeddingPlusPhotoshootDescription</h5>
                        </div>
                        <div class="card-footer text-center">
                            <a asp-controller="Photoshoot" asp-action="ReserveByType" asp-route-photoshootType="@PhotoShootType.WeddingPlus" class="btn btn-primary">РЕЗЕРВИРАЙ</a>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card card-packet">
                        <div class="card-header text-center">
                            <h3>Екстра</h3>
                        </div>
                        <div class="card-body text-center">
                            <h2 class="service-price">@DefaultValue.WeddingExtraPhotoshoot лв</h2>
                            <hr />
                            <h5>@DefaultValue.WeddingExtraPhotoshootDescription</h5>
                        </div>
                        <div class="card-footer text-center">
                            <a asp-controller="Photoshoot" asp-action="ReserveByType" asp-route-photoshootType="@PhotoShootType.WeddingExtra" class="btn btn-primary">РЕЗЕРВИРАЙ</a>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card card-packet">
                        <div class="card-header text-center">
                            <h3>Друго</h3>
                        </div>
                        <div class="card-body text-center">
                            <h2 class="negotiation">@DefaultValue.NegotiablePriceText</h2>
                            <hr />
                            <h5>@DefaultValue.NegotiablePhotoshootDescription</h5>
                        </div>
                        <div class="card-footer text-center">
                            <a asp-controller="Photoshoot" asp-action="ReserveByType" asp-route-photoshootType="@PhotoShootType.Other" class="btn btn-primary">РЕЗЕРВИРАЙ</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="container container-wedding-portfolio mt-5 pt-5">
        <div class="portfolio-item row">
            <div class="item col-md-4 col-6 text-center mt-5">
                <a href="~/img/SamplePhotos/Wedding/svatbena-fotografiya-1.jpg" class="fancylight popup-btn" data-fancybox-group="light">
                    <img class="img-fluid" src="~/img/SamplePhotos/Wedding/svatbena-fotografiya-1.jpg" alt="gallery-item">
                </a>
            </div>
            <div class="item col-md-4 col-6 text-center mt-5">
                <a href="~/img/SamplePhotos/Wedding/svatbena-fotografiya-2.jpg" class="fancylight popup-btn" data-fancybox-group="light">
                    <img class="img-fluid" src="~/img/SamplePhotos/Wedding/svatbena-fotografiya-2.jpg" alt="gallery-item">
                </a>
            </div>
            <div class="item col-md-4 col-6 text-center mt-5">
                <a href="~/img/SamplePhotos/Wedding/svatbena-fotografiya-3.jpg" class="fancylight popup-btn" data-fancybox-group="light">
                    <img class="img-fluid" src="~/img/SamplePhotos/Wedding/svatbena-fotografiya-3.jpg" alt="gallery-item">
                </a>
            </div>

            <div class="item col-md-4 col-6 text-center mt-5">
                <a href="~/img/SamplePhotos/Wedding/svatbena-fotografiya-4.jpg" class="fancylight popup-btn" data-fancybox-group="light">
                    <img class="img-fluid" src="~/img/SamplePhotos/Wedding/svatbena-fotografiya-4.jpg" alt="gallery-item">
                </a>
            </div>
            <div class="item col-md-4 col-6 text-center mt-5">
                <a href="~/img/SamplePhotos/Wedding/svatbena-fotografiya-5.jpg" class="fancylight popup-btn" data-fancybox-group="light">
                    <img class="img-fluid" src="~/img/SamplePhotos/Wedding/svatbena-fotografiya-5.jpg" alt="gallery-item">
                </a>
            </div>
            <div class="item col-md-4 col-6 text-center mt-5">
                <a href="~/img/SamplePhotos/Wedding/svatbena-fotografiya-6.jpg" class="fancylight popup-btn" data-fancybox-group="light">
                    <img class="img-fluid" src="~/img/SamplePhotos/Wedding/svatbena-fotografiya-6.jpg" alt="gallery-item">
                </a>
            </div>
        </div>
    </div>
</div>
<!-- Feature Wedding Photography End -->

<style>
    .card-packet{
        min-height: 400px;
    }
</style>