            case "2":{
                //150 is hardcoded temporary. Soon it will be refactored
                newPrice = 150 * parseInt(numberOfParticipants);
                break;
            }

            //11 is simple product
            case "11":{
                //50 is hardcoded temporary. Soon it will be refactored
                newPrice = 50 * parseInt(numberOfParticipants);
                break;
            }

            //21 is art product
            case "21":{
                //50 is hardcoded temporary. Soon it will be refactored
                newPrice = 50 * parseInt(numberOfParticipants);
                break;
            }

            default:{
                //50 is hardcoded temporary. Soon it will be refactored
                console.log("ivalid photoshoot type");
                break;
            }
        }

        $("#price-summary").text(newPrice + " лв");
        $("#price-summary-euro").text("€ " + convertBgnToEuro(newPrice));
    }

