    //AJAX CALLS

    //get popular places for selected region
    function getPopularPlacesByRegion(regionId) {
        $('#PopularPlaces').selectize()[0].selectize.destroy();
        $.ajax({
            url: "@Url.Action("popularPlacesByRegion", "Place")",
            data: { "regionId": regionId },
            method: "GET",
            success: function (response) {
                let json = JSON.parse(JSON.stringify(response));
                $("#PopularPlaces").selectize({
                    respect_word_boundaries: false,
                    plugins: ["restore_on_backspace", "clear_button"],
                    delimiter: " - ",
                    persist: false,
                    maxItems: 1,
                    valueField: "id",
                    labelField: "name",
                    searchField: ["name"],
                    options: response,
                    onChange: function (value) {
                        $("#IsPlace").val(true);
                        $("#PlaceId").val(value);
                        $("#IsPlaceSelected").val(true);

                        if (value) {
                            $("#SelectedSettlementId").val((findElementById(json, value)).cityId);
                        }
                        
                        isLocationValid();

                        let item = this.$input[0];
                        let selectedText = $(item.selectize.getItem(value)[0]).text();
                        setLocationPlaceSummary(selectedText);

                        //get weather forecast
                        getForecast(value, false);
                    }
                });
            }
        });
    }

    //get settlements for selected region
    function getSettlementsByRegion(region) {
        if (region != '') {
            //destroy Selectize before repopulating the select list with new data
            $('#Settlement').selectize()[0].selectize.destroy();
            $.ajax({
                url: "@Url.Action("settlementsByRegion", "Settlement")",
                method: "GET",
                data: { region: region },
                success: function (response) {
                    $("#Settlement").selectize({
                        respect_word_boundaries: false,
                        plugins: ["restore_on_backspace", "clear_button"],
                        delimiter: " - ",
                        persist: false,
                        maxItems: 1,
                        valueField: "id",
                        labelField: "name",
                        searchField: ["name"],
                        options: response,
                        onChange: function (value) {
                            $("#IsPlace").val(false);
                            $("#SelectedSettlementId").val(value);

                            if(isSettlementsValid()) {
                                //show user place and google maps link inputs
                                //when locationType is custom
                                if(locationType == 'custom'){
                                    $(".row-location-user-place").css("display", "block");
                                    $(".row-location-google-maps-link").css("display", "block");
                                }

                                isLocationValid();

                                let item = this.$input[0];
                                let selectedText = $(item.selectize.getItem(value)[0]).text();
                                setSettlementSummary(selectedText);

                                //get weather forecast
                                getForecast(value, true);
                            }
                        }
                    });
                },
                error: function (response) {
                    console.log("error");
                    console.log(response);
                },
            });
        }
        else {
            //destroy selectize if no region is selected
            $('#Settlement').selectize()[0].selectize.destroy();
        }

    }





    //CONTROL PROGRESS BAR

    function forwardProgress(currentSectionNumber, isLastSection = false) {
        $(".col-progress-bar-section-" + currentSectionNumber).addClass("progress-bar-completed");
        $(".col-progress-bar-section-" + currentSectionNumber).removeClass("progress-bar-current");

        if (!isLastSection) {
            //increment the number to access the next section
            let nextSectionNumber = currentSectionNumber + 1;
            $(".col-progress-bar-section-" + nextSectionNumber).removeClass("progress-bar-pristine");
            $(".col-progress-bar-section-" + nextSectionNumber).addClass("progress-bar-current");
        }

        nextSectionNumber = 0;
    }

    function backwardProgress(currentSectionNumber, isFirstSection) {
        $(".col-progress-bar-section-" + currentSectionNumber).addClass("progress-bar-current");
        $(".col-progress-bar-section-" + currentSectionNumber).removeClass("progress-bar-completed");

        if (!isFirstSection) {
            //decrement the number to access the previous section
            let prevSectionNumber = currentSectionNumber - 1;
            $(".col-progress-bar-section-" + prevSectionNumber).removeClass("progress-bar-completed");
            $(".col-progress-bar-section-" + prevSectionNumber).addClass("progress-bar-current");
        }

        prevSectionNumber = 0;
    }





    //CALCULATE PRICE

    function calculatePrice(photoshootType, fuelPrice = 0) {
        if(photoshootType == "" || photoshootType == undefined){
            return;
        }

        $.ajax({
            contentType: 'application/json',
            url: "@Url.Action("photoshootPrice", "Calculations")",
            traditional: true,
            method: "GET",
            data: { 'photoshootType': photoshootType, 'fuelPrice': fuelPrice },
            success: function (response) {
                if ($("#PhotoShootType").find(":selected").val() == 20 || $("#PhotoShootType").find(":selected").val() == 10) {
                    $("#price-summary").html("По договаряне");
                }
                else {
                    $("#price-summary").html(response + ' лв');
                }
            },
            error: function (response) {
                console.log("error");
                console.log(response);
            }
        });
    }




    //TOGGLE PHOTOSHOOT PACKETS


    //toggle photoshoot packets on photoshootType type change
    function togglePhotoshootPacket(photoshootType){
        console.log(photoshootType);
        let photoshootPacket = mapPhotoshootToPacket(photoshootType);
            
        //hide all packets
        $(".row-photoshoot-packets").css("display", "none"); 

        //show the current one
        $(".row-photoshoot-packets-" + photoshootPacket).css("display", "flex");
    }




    //WEATHER FORECAST
    function getForecast(settlementId, isSettlement) {
        let forecastURL = isSettlement ? "@Url.Action("forecast", "Weather")" : "@Url.Action("forecastForPlace", "Weather")";
        var request = $.ajax({
            url: forecastURL,
            method: "GET",
            data: { settlementId: settlementId },
            success: function (response) {
                let json = JSON.parse(JSON.stringify(response));
                console.log(json);
                $(".card-weather").each(function (i) {
                    console.log(i);
                    if(i == 0){
                        $(this).css("opacity", ".3");
                        $(this).css("pointer-events", "none");
                    }
                    let cardBody = $(this).find(".card-body-weather");
                    //cardBody.find(".icon").css("background-image", `url(${json.forecast.forecastDays[i].day.condition.icon})`);
                    cardBody.find(".temperatureCurrent").text(json.forecast.forecastDays[i].day.averageTemperature != 0 ? (Math.round(json.forecast.forecastDays[i].day.maxTemperature) + 'C°') : '');
                    cardBody.find(".forecastText").text(json.forecast.forecastDays[i].day.condition.text);
                    cardBody.find(".precipitation").text('Валежи: ' + json.forecast.forecastDays[i].day.totalPrecipitation + '%');
                    i++;

                    if(i == 3){
                        return false;
                    }
                });
            },
            error: function (response) {
                console.log("error");
                console.log(response);
            }
        });
    }




    //HELPER FUNCTIONS

    function setDate(dateText) {
        //format date to format yyyy-MM-dd
        //this is used as an input value
        let date = formatSelectedDate(dateText);

        //format date to Bulgarian format dd.MM.yyyy
        //this is used in the summary section as text only
        let dateBGFormat = formatSelectedDateInBulgarianFormat(dateText);

        //set formated date to the input
        $("#ReservationDate").val(date);
        setDateSummary(dateBGFormat);

        //set color to the clicked weather card
        //only if card is available
        if ($(this).hasClass("card-available")) {
            //first, reset the background to the defauilt available
            //so that background does not change for each clicked card
            $(".card-body-available").css("background", "#b8ab6a");

            //then change the background of the current clicked card
            $(this).find(".card-body").css("background", "#000");
        }

        //validate date and time on each date and time card click
        validateDateAndTime();
    }

    function findElementById(array, id) {
        for (let i = 0; i < array.length; i++) {
            if (array[i].id == id) {
                return array[i];
            }
        }
    }

    //format selected date (the date comes in format [dd.mm])
    //the function formats it to format [yyyy-MM-dd]
    function formatSelectedDate(selectedDate) {
        let selectedDateSplit = selectedDate.split('.');
        return `${new Date().getUTCFullYear()}-${selectedDateSplit[1]}-${selectedDateSplit[0]}`;
    }


    //format selected date (the date comes in format [dd.mm])
    //the function formats it to format [dd.MM.yyyy]
    function formatSelectedDateInBulgarianFormat(selectedDate) {
        let selectedDateSplit = selectedDate.split('.');
        return `${selectedDateSplit[0]}.${selectedDateSplit[1]}.${new Date().getUTCFullYear()}`;
    }

    function mapPhotoshootToPacket(photoshootId) {
        switch (photoshootId) {
            case "1": return "personal";
            case "2": return "business-portrait";
            case "3": return "wedding";
            case "5": return "prom";
            case "6": return "family";
            case "7": return "familyPlus";
            case "8": return "familyExtra";
            case "20": return "event";
            case "9": return "automotive";
            case "10": return "other";
            case "11": return "product";
            case "12": return "baptism";
        }
    }
