    function toggleTimeSlots(){
        //hide all timeslots
         $(".btn-time-slot").hide();



         let start = 0;
         let end = 0;

         let timeSlots = $(".btn-time-slot").toArray();

         for (let i = 0; i < timeSlots.length; i++) {
              let card = timeSlots[i].closest('.card-weather');
              let date = $(card).find('.card-header-date-text').first().text();

               if(date.toLowerCase().includes("събота") || date.toLowerCase().includes("неделя")){
                     start = @(Model?.WorkingHoursSpan?.Where(w => w.WorkingTimeType == WorkingTimeType.WeekEnd)?.FirstOrDefault()?.Start ?? 0)
                     end = @(Model?.WorkingHoursSpan?.Where(w => w.WorkingTimeType == WorkingTimeType.WeekEnd)?.FirstOrDefault()?.End ?? 0)
               }

               else{
                    start = @(Model?.WorkingHoursSpan?.Where(w => w.WorkingTimeType == WorkingTimeType.WeekDay)?.FirstOrDefault()?.Start ?? 0)
                     end = @(Model?.WorkingHoursSpan?.Where(w => w.WorkingTimeType == WorkingTimeType.WeekDay)?.FirstOrDefault()?.End ?? 0)
               }
              
              //id looks like this time-slot-4
              //we need to get the hour from the id (the third element)
              let idHour = timeSlots[i].id.split('-')[2];

              if(idHour < start || idHour > end){
                  //hide the time slot if it is not in the working hours span
                  $(timeSlots[i]).hide();
              }
              else{
                  //show the time slot if it is in the working hours span
                  $(timeSlots[i]).show();
              }
         }
    }

    function recalculatePriceWithParticipants(numberOfParticipants){
        let newPrice = 0

        switch($("#PhotoShootType").val()){
