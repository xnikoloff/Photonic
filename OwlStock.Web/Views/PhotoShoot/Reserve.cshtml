    //AJAX CALLS

    //get popular places for selected region
    function getPopularPlacesByRegion(regionId) {
        $('#PopularPlaces').selectize()[0].selectize.destroy();
        $.ajax({
            url: "@Url.Action("popularPlacesByRegion", "Place")",
            data: { "regionId": regionId },
            method: "GET",
            success: function (response) {
                let json = JSON.parse(JSON.stringify(response));
                $("#PopularPlaces").selectize({
                    respect_word_boundaries: false,
                    plugins: ["restore_on_backspace", "clear_button"],
                    delimiter: " - ",
                    persist: false,
                    maxItems: 1,
                    valueField: "id",
                    labelField: "name",
                    searchField: ["name"],
                    options: response,
                    onChange: function (value) {
                        $("#IsPlace").val(true);
                        $("#PlaceId").val(value);
                        $("#IsPlaceSelected").val(true);

                        if (value) {
                            $("#SelectedSettlementId").val((findElementById(json, value)).cityId);
                        }
                        
                        isLocationValid();

                        let item = this.$input[0];
                        let selectedText = $(item.selectize.getItem(value)[0]).text();
                        setLocationPlaceSummary(selectedText);

                        //get weather forecast
                        getForecast(value, false);
                    }
                });
            }
        });
    }

    //get settlements for selected region
    function getSettlementsByRegion(region) {
        if (region != '') {
            //destroy Selectize before repopulating the select list with new data
            $('#Settlement').selectize()[0].selectize.destroy();
            $.ajax({
                url: "@Url.Action("settlementsByRegion", "Settlement")",
                method: "GET",
                data: { region: region },
                success: function (response) {
                    $("#Settlement").selectize({
                        respect_word_boundaries: false,
                        plugins: ["restore_on_backspace", "clear_button"],
                        delimiter: " - ",
                        persist: false,
                        maxItems: 1,
                        valueField: "id",
                        labelField: "name",
                        searchField: ["name"],
                        options: response,
                        onChange: function (value) {
                            $("#IsPlace").val(false);
                            $("#SelectedSettlementId").val(value);

                            if(isSettlementsValid()) {
                                //show user place and google maps link inputs
                                //when locationType is custom
                                if(locationType == 'custom'){
                                    $(".row-location-user-place").css("display", "block");
                                    $(".row-location-google-maps-link").css("display", "block");
                                }

                                isLocationValid();

                                let item = this.$input[0];
                                let selectedText = $(item.selectize.getItem(value)[0]).text();
                                setSettlementSummary(selectedText);

                                //get weather forecast
                                getForecast(value, true);
                            }
                        }
                    });
                },
                error: function (response) {
                    console.log("error");
                    console.log(response);
                },
            });
        }
        else {
            //destroy selectize if no region is selected
            $('#Settlement').selectize()[0].selectize.destroy();
        }

    }





    //CONTROL PROGRESS BAR

    function forwardProgress(currentSectionNumber, isLastSection = false) {
        $(".col-progress-bar-section-" + currentSectionNumber).addClass("progress-bar-completed");
        $(".col-progress-bar-section-" + currentSectionNumber).removeClass("progress-bar-current");

        if (!isLastSection) {
            //increment the number to access the next section
            let nextSectionNumber = currentSectionNumber + 1;
            $(".col-progress-bar-section-" + nextSectionNumber).removeClass("progress-bar-pristine");
            $(".col-progress-bar-section-" + nextSectionNumber).addClass("progress-bar-current");
        }

        nextSectionNumber = 0;
    }

    function backwardProgress(currentSectionNumber, isFirstSection) {
        $(".col-progress-bar-section-" + currentSectionNumber).addClass("progress-bar-current");
        $(".col-progress-bar-section-" + currentSectionNumber).removeClass("progress-bar-completed");

        if (!isFirstSection) {
            //decrement the number to access the previous section
            let prevSectionNumber = currentSectionNumber - 1;
            $(".col-progress-bar-section-" + prevSectionNumber).removeClass("progress-bar-completed");
            $(".col-progress-bar-section-" + prevSectionNumber).addClass("progress-bar-current");
        }

        prevSectionNumber = 0;
    }





    //CALCULATE PRICE

    function calculatePrice(photoshootType, fuelPrice = 0) {
        if(photoshootType == "" || photoshootType == undefined){
            return;
        }

         let numberOfParticipants = $("#NumberOfParticipants").val();

        $.ajax({
            contentType: 'application/json',
            url: "@Url.Action("photoshootPrice", "Calculations")",
            traditional: true,
            method: "GET",
              data: { 'photoshootType': photoshootType, 'fuelPrice': fuelPrice, 'numberOfParticipants': numberOfParticipants },
            success: function (response) {
                if ($("#PhotoShootType").find(":selected").val() == 20 || $("#PhotoShootType").find(":selected").val() == 10) {
                    $("#price-summary").html("По договаряне");
                    $("#price-summary-euro").html("-");
                }
                else {
                    $("#price-summary").html(response + ' лв');
                    $("#price-summary-euro").html('€ ' + convertBgnToEuro(response));
                }
            },
            error: function (response) {
                console.log("error");
                console.log(response);
            }
        });
    }




