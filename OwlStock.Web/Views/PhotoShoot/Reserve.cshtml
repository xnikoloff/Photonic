    //VALIDATIONS

    //validate section one -> photoshoot type
    function isPhotoshootTypeValid() {
        if ($("#PhotoShootType").val() == '' || $("#PhotoShootType").val() == undefined) {
            $(".btn-section-submit-seciton-1").prop("disabled", true);
            return false;
        }

        else {
            $(".btn-section-submit-seciton-1").prop("disabled", false);
            return true;
        }
    }





    //validate section 2 -> location
    function isLocationValid() {
        if (locationType == '' || locationType == undefined) {
            //if location type is not defined, 
            // it must mean that this is the first to time to open section two
            //so, set location type to popular (popular location tab is selected by default)
            locationType = 'popular';
        }

        switch (locationType) {
            case "popular": {
                isPopularLocationValid();
                break;
            }

            case "custom": {
                isCustomLocationValid();
                break;
            }

            case "decidedByUs": {
                isLocationDecidedByUsValid();
                break;
            }

            default: {
                console.log('location type: ' + locationType + ' is invalid');
            }
        }
    }



    //validate popular places
    function isPopularLocationValid() {
        if (isRegionValid() && isPopularPlacesValid()) {
            $(".btn-section-submit-seciton-2").prop("disabled", false);
            return true;
        }
        else {
            $(".btn-section-submit-seciton-2").prop("disabled", true);
            return false;
        }
    }

