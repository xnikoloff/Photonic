<script>
   //global variable, keeps the location type on location type change
    var locationType = '';
    $(document).ready(function () {
        //show photoshoot sub categories on page load
        //if a photoshoot is pre-selected 
        togglePhotoshootPacket($("#PhotoShootType").val());

