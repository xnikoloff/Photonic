                                                    <div id="date-buttons-slider">
                                                        @foreach (KeyValuePair<DateOnly, IEnumerable<TimeSlot>> calendarKVP in calendar)
                                                        {
                                                            var firstSlot = calendarKVP.Value.FirstOrDefault() ?? new TimeSlot(new TimeOnly(), false);
                                                            var isAvailable = firstSlot.IsAvailable;
                                                            var backgroundColor = isAvailable ? "#a2bab3" : "#51565c";
                                                            var iconHtml = isAvailable ? "<i class=\"fa-solid fa-check fa-lg\" style=\"color:#a2bab3\"></i>" : "<i class=\"fa-solid fa-xmark fa-lg\" style=\"color:#874d4d\"></i>";

                                                            <div class="card card-weather text-center btn-date btn-date-simple text-white @(isAvailable ? "bg-primary card-available" : "bg-secondary card-unavailable")" id="date-button-simple">
                                                                <div class="card-header card-header-date">
                                                                    <p class="card-header-date-text">
                                                                        @{
                                                                            DayOfWeek dayOfWeek = calendarKVP.Key.DayOfWeek;
                                                                            CultureInfo cultureInfo = new("bg-BG");
                                                                            string dayName = DateTimeFormatInfo.GetInstance(cultureInfo).GetDayName(dayOfWeek);
                                                                        }
                                                                        @dayName
                                                                    </p>

                                                                    @if (calendarKVP.Key.Year > DateTime.Now.Year)
                                                                    {
                                                                        <p class="card-header-date-num">@calendarKVP.Key.ToString("dd.MM.yyyy")</p>
                                                                    }
                                                                    else
                                                                    {
                                                                        <p class="card-header-date-num">@calendarKVP.Key.ToString("dd.MM")</p>
                                                                    }

                                                                </div>
                                                                <div class="card-body card-body-weather text-center @(isAvailable ? "card-body-available" : "card-body-unavailable")" style="background: @Html.Raw(backgroundColor)">
                                                                    @foreach (TimeSlot slot in calendarKVP.Value)
                                                                    {
                                                                        <button type="button" class="btn @(slot.IsAvailable ? "btn-primary time-slot-available" : "btn-secondary time-slot-unavailable") text-white btn-sm my-1 btn-time-slot" id="time-slot-@(slot.Time.Hour)">
                                                                            @(slot.Time.Hour < 10 ? $"0{slot.Time.Hour}" : slot.Time.Hour):@(slot.Time.Minute == 0 ? "00" : "30")
                                                                        </button>
                                                                    }
                                                                    <hr />
                                                                    <p class="temperatureCurrent weather-info-text"></p>
                                                                    <p class="icon weather-info-text"></p>
                                                                    <p class="forecastText">Нямаме информация за времето</p>
                                                                    <p class="precipitation weather-info-text"></p>
                                                                </div>
                                                                <div class="card-footer">
                                                                    @Html.Raw(iconHtml)
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
