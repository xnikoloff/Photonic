@model HomePageDTO

@{
    ViewData["Title"] = "Индивидуална и бизнес фотография";
}

<!-- Carousel Start -->
<div class="container-fluid p-0 pb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="owl-carousel header-carousel position-relative">
        <div class="owl-carousel-item position-relative img-fluid-banner-wrap" data-dot="<img src='img/carousel-1.jpg'>">
            <img class="img-fluid" src="~/img/carousel-1.jpg" alt="">
            <div class="owl-carousel-inner">
                <div class="container-fluid carousel-inner-container removeOnMobileFlag">
                    <div class="row justify-content-end text-end">
                        <div class="col-12 col-lg-6 banner-wrap-texts">
                            <h4 class="text-white animated slideInDown banner-subheading">Нашето вдъхновение са вашите спомени</h4>
                            <h1 class="display-2 text-white animated slideInDown banner-heading">Индивидуални фотосесии</h1>
                            <p class="fs-5 fw-medium text-white mb-4 pb-3 banner-text">Подарете си време за себе си и преживяване, което улавя най-доброто от вас — момент, превърнат в изкуство</p>
                            <a asp-controller="Photo" asp-action="Portfolio" asp-route-category="@Category.Portrait" class="btn btn-primary py-3 px-5 animated slideInLeft">Портфолио</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="owl-carousel-item position-relative img-fluid-banner-wrap" data-dot="<img <img src='img/carousel-2.jpg'>">
            <img class="img-fluid" src="~/img/carousel-2.jpg" alt="">
            <div class="owl-carousel-inner">
                <div class="container-fluid carousel-inner-container removeOnMobileFlag">
                    <div class="row justify-content-end text-end">
                        <div class="col-12 col-lg-6 banner-wrap-texts">
                            <h4 class="text-white animated slideInDown banner-subheading">Нашето вдъхновение са вашите спомени</h4>
                            <h1 class="display-1 text-white animated slideInDown banner-heading">Сватбени портрети</h1>
                            <p class="fs-5 fw-medium text-white mb-4 pb-3 banner-text">Ценим тишината между големите събития, усмивките, които не са режисирани, и докосванията, които говорят повече от думите...</p>
                            <a asp-controller ="Photo" asp-action="Portfolio" asp-route-category="@Category.Wedding" class="btn btn-primary py-3 px-5 animated slideInLeft">Портфолио</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="owl-carousel-item position-relative img-fluid-banner-wrap" data-dot="<img src='img/carousel-3.jpg'>">
            <img class="img-fluid" src="~/img/carousel-3.jpg" alt="">
            <div class="owl-carousel-inner">
                <div class="container-fluid carousel-inner-container removeOnMobileFlag">
                    <div class="row justify-content-end text-end">
                        <div class="col-12 col-lg-6 banner-wrap-texts">
                            <h4 class="text-white animated slideInDown banner-subheading">Нашето вдъхновение са вашите спомени</h4>
                            <h1 class="display-2 text-white animated slideInDown banner-heading">Абитуриентски бал</h1>
                            <p class="fs-5 fw-medium text-white mb-4 pb-3 banner-text">Това е вечерта, в която празнувате края на едно важно приключение и началото на следващата голяма стъпка.</p>
                            <a asp-controller="Photo" asp-action="Portfolio" asp-route-category="@Category.Prom" class="btn btn-primary py-3 px-5 animated slideInLeft">Портфолио</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="owl-carousel-item position-relative img-fluid-banner-wrap" data-dot="<img src='img/carousel-4.jpg'>">
            <img class="img-fluid" id="img-fluid-banner-replace" src="img/carousel-4.jpg" alt="">
            <div class="owl-carousel-inner">
                <div class="container-fluid carousel-inner-container removeOnMobileFlag">
                    <div class="row justify-content-end text-end">
                        <div class="col-12 col-lg-6 banner-wrap-texts">
                            <h4 class="text-white animated slideInDown banner-subheading">Нашето вдъхновение са вашите спомени</h4>
                            <h1 class="display-1 text-white animated slideInDown banner-heading">Автомобилна фотография</h1>
                            <p class="fs-5 fw-medium text-white mb-4 pb-3 banner-text">Ще подберем правилните ъгли и светлина, за да покажем колата по начин, който отговаря на нейния характер – динамична и елегантна или просто практична и надеждна</p>
                            <a asp-controller="Photo" asp-action="Portfolio" asp-route-category="@Category.Automotive" class="btn btn-primary py-3 px-5 animated slideInLeft">Портфолио</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Carousel End -->
<!-- Service Start -->
<div class="container my-5 py-5">
    <div class="col-lg-6 wow fadeInUp mx-auto text-center" data-wow-delay="0.5s">
        <div class="h-100">
            <p class="text-primary text-uppercase mb-2">Услуги</p>
            <h1 class="display-6 mb-4">НАШИТЕ УСЛУГИ</h1>
            <p>Във <span class="text-primary"><b>PHOTONIC</b></span> предлагаме разнообразие от фотографски услуги, създадени да уловят и съхранят най-ценните ви моменти.</p>
            <hr class="w-50 mx-auto mb-5 mb-xl-9 border-dark-subtle">
        </div>
    </div>
    <partial name="_GalleryCategories" model="false"></partial>
</div>
<!-- Service End -->
<!-- About Start -->
<div class="container-xxl py-5">
    <div class="container py-5">
        <div class="row g-5">
            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.1s">
                <div class="about-img">
                    <img class="img-fluid" src="img/about-1.jpg" alt="">
                    <img class="img-fluid" src="img/about-2.jpg" alt="">
                </div>
            </div>
            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.5s">
                <h4 class="section-title">За нас</h4>
                <h1 class="display-5 mb-4">ПОВЕЧЕ ЗА НАС И НАШАТА ДЕЙНОСТ</h1>
                <p >Ние сме малък екип от хора, които правят това, което обичат и обичат това, което правят. За нас фотографията не е просто работа, а начин да превръщаме вашите моменти в картини, които бихте окачили на стената или използвали стратегически за бизнеса си.</p>
                <p class="mb-4">Нашата цел е да запазим вашите моменти чрез картините, които „рисуваме“ с фотоапарат. Независимо дали сме на вашия абитуриентски бал, на вашето корпоративно събитие или просто снимаме вашия личен портрет, ще създадем картини, които ще може да окачите на стената и да поглеждате с лека носталгия, но и с удовлетвореност, че тя стои там и краси дома или офиса ви.</p>
                <div class="d-flex align-items-center mb-3">
                    <!--<div class="d-flex flex-shrink-0 align-items-center justify-content-center border border-5 border-primary" style="width: 120px; height: 120px;">
                        <h1 class="display-1 mb-n2" data-toggle="counter-up">25</h1>
                    </div>-->
                    <!--<div class="ps-4">
                        <h3>Years</h3>
                        <h3>Working</h3>
                        <h3 class="mb-0">Experience</h3>
                    </div>-->
                </div>
                <a class="btn btn-primary py-3 px-5" asp-controller="StaticContent" asp-action="About">Научете повече</a>
            </div>
        </div>
    </div>
</div>
<!-- About End -->
<!-- Team Start -->
<div class="container-xxl py-5">
    <div class="container py-5">
        <div class="text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 600px;">
            <h4 class="section-title">Актуално</h4>
            <h1 class="display-5 mb-4">ПОСЛЕДНИТЕ НОВИНИ И ПУБЛИКАЦИИ</h1>
        </div>
        <div class="row g-0 team-items">
            @foreach (DynamicContent dynamicContent in Model?.DynamicContents ?? new List<DynamicContent>())
            {
                <div class="col-lg-3 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                    <div class="team-item position-relative">
                        <div class="position-relative">
                            <img class="img-fluid" src="~/resources/images/@(dynamicContent.ImageName)" alt="">
                            <!--<div class="team-social text-center">
                                <a class="btn btn-square" href=""><i class="fab fa-facebook-f"></i></a>
                                <a class="btn btn-square" href=""><i class="fab fa-twitter"></i></a>
                                <a class="btn btn-square" href=""><i class="fab fa-instagram"></i></a>
                            </div>-->
                        </div>
                        <div class="bg-light text-center p-4 dynamic-content-title-wrap">
                            <h3 class="mt-2"><a class="text-dark" asp-action="Content" asp-controller="DynamicContent" asp-route-id="@dynamicContent?.Id">@(dynamicContent?.Title ?? "")</a></h3>
                        </div>
                        <div class="bg-primary text-center p-4">
                            <span class="text-light"><a asp-action="AllByCategory" asp-controller="DynamicContent" asp-route-id="@dynamicContent?.DynamicContentCategories?.Id" class="text-light">@(dynamicContent?.DynamicContentCategories?.Name ?? "")</a> | @(dynamicContent?.CreatedOn.ToString("dd.MM.yyyy") ?? "") г.</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
<!-- Team End -->

<!-- Testimonial Start -->
<div class="container-xxl container-testimonials py-5">
    <div class="container py-5">
        <div class="text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 6B00px;">
            <h4 class="section-title">Оценки</h4>
            <h1 class="display-5 mb-4">НАШИТЕ КЛИЕНТИ</h1>
        </div>
        <div class="owl-carousel testimonial-carousel wow fadeInUp" data-wow-delay="0.1s">
            @foreach (Testimony testimony in Model?.Testimonies ?? new List<Testimony>())
            {
                <div class="testimonial-item text-center" data-dot="">
                    <img src="~/img/icons/user-icon.png" class="text-center mx-auto pb-4" style="width:80px"/>
                    <p class="fs-5">@testimony.Content</p>
                    <h3>@((testimony.PersonFirstName ?? "") + " " + (testimony.PersonLastName ?? ""))</h3>
                    <span class="text-primary">
                        @(
                            testimony.PersonJob == string.Empty  || testimony.PersonJob == null ? "Няма професия" : testimony.PersonJob
                        )
                    </span>
                    <div class="star">
                        @for (int i = 0; i < testimony.Stars; i++)
                        {
                            string foo = testimony.PersonJob ?? "";
                            <i class="fa fa-star text-warning"></i>
                        }
                        @for (int i = testimony.Stars + 1; i <= 5; i++)
                        {
                            <i class="fa fa-star"></i>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>
<!-- Testimonial End -->
<div class="pb-5">
    <partial name="_CreateTestimony" model="new CreateTestimonyDTO()"></partial>
</div>

<style>
    .wrap-create-testimony {
        margin-top: 200px;
        padding-bottom: 50px;
        background: #f9f9ff;
    }

    .dynamic-content-title-wrap {
        min-height: 200px !important;
    }

    .carousel-inner-container {
        padding: 0 200px !important;
    }

   @@media (max-width: 768px) {
        .img-fluid-banner-wrap{
            min-height: 800px !important;
        }

        .carousel-inner-container .banner-wrap-texts{
            width: 400px !important;
        }

        .carousel-inner-container {
            padding: 0 20px !important;
        }
   }
</style>

<script>
    $(document).ready(function() {
        swapBanner();
    });

    function swapBanner() {
        let height = window.screen.availHeight;
        let width = window.screen.availWidth;
        let banner = document.getElementById('img-fluid-banner-replace');
        
        if(height > width){
            banner.src = 'img/carousel-4-mobile.jpg';
        }
        else{
            banner.src = 'img/carousel-4.jpg';
        }
    }
</script>                            