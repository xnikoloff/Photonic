@model HomePageDTO

@{
    ViewData["Title"] = "Фотографска агенция";
}

<!--================Banner Area =================-->
<section class="banner_area">
    <div class="booking_table d_flex align-items-center">
        <div class="overlay bg-parallax" data-stellar-ratio="0.9" data-stellar-vertical-offset="0" data-background=""></div>
        <div class="container">
            <div class="banner_content text-center">
                <h6>Фотографска агенция</h6>
                <img src="~/photonicBIG.png" class="logo-homepage" />
                <p>Нашето вдъхновение са вашите спомени</p>
            </div>
        </div>
    </div>
    @await Component.InvokeAsync("QuickBooking")
</section>
<!--================Banner Area =================-->
<!--================ Accomodation Area  =================-->
<section class="accomodation_area section_gap">
    <div class="container">
        <div class="section_title text-center">
            <h2 class="title_color">Повече за нас</h2>
            <p>Услуги, цени, творчесто, мисия</p>
        </div>
        <div class="row mb_30">
            <div class="col-lg-3 col-sm-6">
                <div class="accomodation_item text-center">
                    <div class="hotel_img">
                        <img src="~/resources/images/services-photoshoot.jpg" alt="services-photoshoot">
                        <a asp-controller="StaticContent" asp-action="Services" class="btn theme_btn button_hover">Услуги</a>
                    </div>
                    <p class="services-subheading">Потърсете ни за всичко, което искате да се превърне в спомен</p>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="accomodation_item text-center">
                    <div class="hotel_img">
                        <img src="~/resources/images/prices-calculator.jpg" alt="">
                        <a asp-controller="StaticContent" asp-action="Pricing" class="btn theme_btn button_hover">Цени</a>
                    </div>
                    <p class="services-subheading">Разгледайте ценовата гама на предлаганите от нас услуги</p>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="accomodation_item text-center">
                    <div class="hotel_img">
                        <img src="~/resources/images/gallery-album.jpg" alt="">
                        <a asp-controller="Photo" asp-action="Index" class="btn theme_btn button_hover">Галерия</a>
                    </div>
                    <p class="services-subheading">Вдъхновете се от нашите вече направени фотографии</p>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="accomodation_item text-center">
                    <div class="hotel_img">
                        <img src="~/resources/images/about-us-clones.jpg" alt="">
                        <a asp-controller="StaticContent" asp-action="About" class="btn theme_btn button_hover">За нас</a>
                    </div>
                    <p class="services-subheading">Научете повече за нашата дейност и история</p>
                </div>
            </div>
        </div>
    </div>
</section>
<section class="container">
    <div class="section_title text-center">
        <h2 class="title_color">Фотосесии</h2>
        <p>Резервирайте лесно, удобно и напълно безплатно вашата следваща фотосесия</p>
    </div>
    <partial name="_GalleryCategories" model="true"></partial>
</section>
<!-- Portfolio Grid-->
<!--================ Accomodation Area  =================-->
<!--================ About History Area  =================-->
<section class="about_history_area section_gap">
    <div class="container">
        <div class="row">
            <div class="col-md-6 d_flex align-items-center">
                <div class="about_content ">
                    <h2 class="title title_color">За нас <br>Нашата история<br>Какво целим</h2>
                    <p>Фотоник се роди с идеята да улесни максимално клиентите си. Всички знаем колко е неприятно да очаквате с нетърпение „флашката“, на която фотографът е записал снимките от фотосесията Ви, а тя да се окаже повредена. Никой ме е виновен за това - просто се случва. И именно защото знаем, че се случва, създадохме сайта на нашата агенция, където споделяме снимките Ви без размяна на физически копия.</p>
                    <a asp-action="About" asp-controller="StaticContent" class="button_hover theme_btn_two">Научете повече</a>
                </div>
            </div>
            <div class="col-md-6">
                <img class="img-fluid" src="image/about_bg.jpg" alt="img">
            </div>
        </div>
    </div>
</section>
<!--================ About History Area  =================-->
<!--================ Latest Blog Area  =================-->
<section class="latest_blog_area section_gap">
    <div class="container">
        <div class="section_title text-center">
            <h2 class="title_color">Актуално</h2>
            <p>Последните публиакции от нашия блог</p>
        </div>
        <div class="row mb_30">
            @foreach (DynamicContent dynamicContent in Model?.DynamicContents ?? new List<DynamicContent>())
            {
                <div class="col-lg-4 col-md-6">
                    <div class="single-recent-blog-post">
                        <div class="thumb">
                            <img class="img-fluid" src="~/resources/images/@(dynamicContent.ImageName)" alt="post">
                        </div>
                        <div class="details">
                            <div class="tags">
                                <a asp-action="AllByCategory" asp-controller="DynamicContent" asp-route-id="@dynamicContent?.DynamicContentCategories?.Id" class="button_hover tag_btn">@dynamicContent?.DynamicContentCategories?.Name</a>
                            </div>
                            <a asp-action="Content" asp-controller="DynamicContent" asp-route-id="@dynamicContent?.Id"><h4 class="sec_h4">@dynamicContent?.Title</h4></a>
                            <p>@dynamicContent?.Description</p>
                            <h6 class="date title_color">@dynamicContent?.CreatedOn.ToString("dd.MM.yyyy") г.</h6>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
<!--================ Recent Area  =================-->
<!--================ Testimonial Area  =================-->
<section class="testimonial_area section_gap">
    <div class="container">
        <div class="section_title text-center">
            <h2 class="title_color">Какво говорят клиентите ни</h2>
            <p>Прочетете какво мислят клиентите ни за нашата дейност</p>
        </div>
        <div class="testimonial_slider owl-carousel">
            @foreach(Testimony testimony in Model?.Testimonies ?? new List<Testimony>())
            {
                <div class="media testimonial_item">
                    <img class="rounded-circle" src="image/user-testimony.png" alt="user-testimony" style="width: 80px">
                    <div class="media-body">
                        <h4 class="sec_h4">@testimony.PersonFirstName @testimony.PersonLastName</h4>
                        <div class="star">
                            @for(int i = 0; i < testimony.Stars; i++)
                            {
                                <i class="fa fa-star text-warning"></i>
                            }
                            @for(int i = testimony.Stars + 1; i <= 5; i++)
                            {
                                <i class="fa fa-star"></i>
                            }
                        </div>
                        <p class="mt-3">@testimony.Content</p>
                    </div>
                </div>
            }
        </div>
    </div>
    <div class="container testimony-container">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="tesimonail-container-title">Ще се радваме да чуем и Вашето мнение</h1>
            </div>
        </div>
        <partial name="_CreateTestimony" model="new Testimony()"></partial>
    </div>
</section>
<!--================ Testimonial Area  =================-->
<style>
    .testimonial_item{
        min-height: 380px;
    }

    .testimony-container{
        margin-top: 100px;
    }

    .testimony-container input, .testimony-container textarea{
        border: none;
        border-radius: 0;
    }

    .book_now_btn{
        font-weight: bold;
    }

    .services-subheading{
        margin-top: 30px;
    }

    /*Override from styles.css*/
    .banner_area .bg-parallax {
        background: url(@(Url.Content($"~/resources/{ViewBag.HomePhoto}"))) no-repeat scroll center 0/cover;
        opacity: 0.50;
    }
    header.masthead {
        background: linear-gradient( rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5) ), url(@(Url.Content($"~/resources/{ViewBag.HomePhoto}")));
        background-size: cover;
    }

    .masthead-heading-wrapper{
        transform: scale(.5);
        animation-name: animateMastheadTexts;
        animation-duration: 2s;
        transform: scale(1);
    }

    #your-colored{
        color: #ffc800;
        font-weight: bold;
    }

    .btn-book{
        animation-name: animateBookButton;
        animation-delay: 2s;
        animation-iteration-count: infinite;
        animation-duration: 2s;
    }

    .btn-book:hover {
        animation-name: unset;
    }

    .icons-container {
        padding: 150px 0;
    }

    .icons-container .icons-column {
        margin: 0 auto;
        padding-bottom: 80px;
        text-align: center;
        border-right: 1px solid #dbdbdb;
        transition: .4s;
    }

    .icons-container .icons-column:last-child {
        border-right: unset;
    }

    .icons-container .icons-column .icon-title {
        margin-top: 30px;
        margin-bottom: 20px;
    }

    .icons-container .icons-column .icon-text{
        min-height: 90px;
    }

    @@media only screen and (max-width: 768px){
        .icons-container .icons-column .icon-text {
            min-height: 40px;
        }

        .logo-homepage {
            width: 350px;
        }

        header.masthead{
            padding-top: 100px;
            
        }

        header.masthead .dimmer {
            
        }
    }
    @@keyframes animateMastheadTexts {
        from {
            transform: scale(.5);
        }

        to {
            transform: scale(1);
        }
    }

    @@keyframes animateBookButton{
        0% {
            transform: unset;
            box-shadow: 0px 0px 22px #ffc800;
        }

        50% {
            transform: scale(0.9);
            box-shadow: 0px 0px 8px #ffc800;
        }

        100%{
            box-shadow: 0px 0px 22px #ffc800;
        }
    }
</style>

<script src="~/js/custom/helpers.js"></script>
<script>
    $(document).ready(function () {
        //filter select options for photoshoot type
        filterPhotoshootTypeOptions();
    });
</script>