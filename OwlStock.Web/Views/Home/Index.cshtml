                    </div>
                    <p class="services-subheading">Разгледайте ценовата гама на предлаганите от нас услуги</p>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="accomodation_item text-center">
                    <div class="hotel_img">
                        <img src="~/resources/images/gallery-album.jpg" alt="">
                        <a asp-controller="Photo" asp-action="Index" class="btn theme_btn button_hover">Галерия</a>
                    </div>
                    <p class="services-subheading">Вдъхновете се от нашите вече направени фотографии</p>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="accomodation_item text-center">
                    <div class="hotel_img">
                        <img src="~/resources/images/about-us-clones.jpg" alt="">
                        <a asp-controller="StaticContent" asp-action="About" class="btn theme_btn button_hover">За нас</a>
                    </div>
                    <p class="services-subheading">Научете повече за нашата дейност и история</p>
                </div>
            </div>
        </div>
    </div>
</section>


<!--================ Accomodation Area  =================-->
<!--================ About History Area  =================-->
<section class="about_history_area section_gap">
    <div class="container">
        <div class="row">
            <div class="col-md-6 d_flex align-items-center">
                <div class="about_content ">
                    <h2 class="title title_color">За нас <br>Нашата история<br>Какво целим</h2>
                    <p>Фотоник се роди с идеята да улесни максимално клиентите си. Всички знаем колко е неприятно да очаквате с нетърпение „флашката“, на която фотографът е записал снимките от фотосесията Ви, а тя да се окаже повредена. Никой не е виновен за това - просто се случва. И именно защото знаем, че се случва, създадохме сайта на нашата агенция, където споделяме снимките Ви без размяна на физически копия.</p>
                    <a asp-action="About" asp-controller="StaticContent" class="button_hover theme_btn_two">Научете повече</a>
                </div>
            </div>
            <div class="col-md-6">
                <img class="img-fluid" src="image/about_bg.jpg" alt="img">
            </div>
        </div>
    </div>
</section>
<!--================ About History Area  =================-->
<!--================ Latest Blog Area  =================-->
<section class="latest_blog_area section_gap">
    <div class="container">
        <div class="section_title text-center">
            <h2 class="title_color">Актуално</h2>
            <p>Последните публиакции от нашия блог</p>
        </div>
        <div class="row mb_30">
            @foreach (DynamicContent dynamicContent in Model?.DynamicContents ?? new List<DynamicContent>())
            {
                <div class="col-lg-4 col-md-6">
                    <div class="single-recent-blog-post">
                        <div class="thumb">
                            <img class="img-fluid" src="~/resources/images/@(dynamicContent.ImageName)" alt="post">
                        </div>
                        <div class="details">
                            <div class="tags">
                                <a asp-action="AllByCategory" asp-controller="DynamicContent" asp-route-id="@dynamicContent?.DynamicContentCategories?.Id" class="button_hover tag_btn">@dynamicContent?.DynamicContentCategories?.Name</a>
                            </div>
                            <a asp-action="Content" asp-controller="DynamicContent" asp-route-id="@dynamicContent?.Id"><h4 class="sec_h4">@dynamicContent?.Title</h4></a>
                            <p>@dynamicContent?.Description</p>
                            <h6 class="date title_color">@dynamicContent?.CreatedOn.ToString("dd.MM.yyyy") г.</h6>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="row mt-5">
            <div class="col-12 text-center">
                <a asp-action="AllByPage" asp-controller="DynamicContent" class="btn theme_btn button_hover">Виж всички</a>
            </div>
        </div>
    </div>
</section>
<!--================ Recent Area  =================-->
<!--================ Testimonial Area  =================-->
<section class="testimonial_area section_gap">
    <div class="container">
        <div class="section_title text-center">
            <h2 class="title_color">Какво говорят клиентите ни</h2>
            <p>Прочетете какво мислят клиентите ни за нашата дейност</p>
        </div>
        <div class="testimonial_slider owl-carousel">
            @foreach(Testimony testimony in Model?.Testimonies ?? new List<Testimony>())
            {
                <div class="media testimonial_item">
                    <img class="rounded-circle" src="image/user-testimony.png" alt="user-testimony" style="width: 80px">
                    <div class="media-body">
                        <h4 class="sec_h4">@testimony.PersonFirstName @testimony.PersonLastName</h4>
                        <div class="star">
                            @for(int i = 0; i < testimony.Stars; i++)
                            {
                                <i class="fa fa-star text-warning"></i>
                            }
                            @for(int i = testimony.Stars + 1; i <= 5; i++)
                            {
                                <i class="fa fa-star"></i>
                            }
                        </div>
                        <p class="mt-3">@testimony.Content</p>
                    </div>
                </div>
            }
        </div>
    </div>
    <div class="container testimony-container">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="tesimonail-container-title">Ще се радваме да чуем и Вашето мнение</h1>
            </div>
        </div>
        <partial name="_CreateTestimony" model="new Testimony()"></partial>
    </div>
</section>
<!--================ Testimonial Area  =================-->
