<!--================ Latest Blog Area  =================-->
<section class="latest_blog_area section_gap">
    <div class="container">
        <div class="section_title text-center">
            <h2 class="title_color">Актуално</h2>
            <p>Последните публиакции от нашия блог</p>
        </div>
        <div class="row mb_30">
            @foreach (DynamicContent dynamicContent in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="single-recent-blog-post">
                        <div class="thumb">
                            <img class="img-fluid" src="~/resources/images/@(dynamicContent.ImageName)" alt="post">
                        </div>
                        <div class="details">
                            <div class="tags">
                                <a href="#" class="button_hover tag_btn">Travel</a>
                                <a href="#" class="button_hover tag_btn">Life Style</a>
                            </div>
                            <a href="#"><h4 class="sec_h4">@dynamicContent.Title</h4></a>
                            <p>@dynamicContent.Description</p>
                            <h6 class="date title_color">@dynamicContent.CreatedOn.ToString("dd.MM.yyyy") г.</h6>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
<!--================ Recent Area  =================-->

<style>
    .book_now_btn{
        font-weight: bold;
    }

    .services-subheading{
        margin-top: 30px;
    }

    /*Override from styles.css*/
    .banner_area .bg-parallax {
        background: url(@(Url.Content($"~/resources/{ViewBag.HomePhoto}"))) no-repeat scroll center 0/cover;
        opacity: 0.50;
    }
    header.masthead {
        background: linear-gradient( rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5) ), url(@(Url.Content($"~/resources/{ViewBag.HomePhoto}")));
        background-size: cover;
    }

    .masthead-heading-wrapper{
        transform: scale(.5);
        animation-name: animateMastheadTexts;
        animation-duration: 2s;
        transform: scale(1);
    }

    #your-colored{
        color: #ffc800;
        font-weight: bold;
    }

    .btn-book{
        animation-name: animateBookButton;
        animation-delay: 2s;
        animation-iteration-count: infinite;
        animation-duration: 2s;
    }

    .btn-book:hover {
        animation-name: unset;
    }

    .icons-container {
        padding: 150px 0;
    }

    .icons-container .icons-column {
        margin: 0 auto;
        padding-bottom: 80px;
        text-align: center;
        border-right: 1px solid #dbdbdb;
        transition: .4s;
    }

    .icons-container .icons-column:last-child {
        border-right: unset;
    }

    .icons-container .icons-column .icon-title {
        margin-top: 30px;
        margin-bottom: 20px;
    }

    .icons-container .icons-column .icon-text{
        min-height: 90px;
    }

    .row-portfolio{
        margin-top: 80px;
    }

    .row-portfolio .col-portfolio{
        background-size: cover;
    }

    .row-portfolio .col-portfolio h1 {
        margin-top: 80px;
        padding: 0 60px;
        color: #fff;
    }

    .row-portfolio .col-portfolio p {
        margin-top: 20px;
        padding: 0 60px;
        color: #fff;
    }

    .row-portfolio .col-portfolio a {
        margin-top: 20px;
        margin-bottom: 50px;
    }

    .row-portfolio .col-portfolio .portfolio-content-wrap{
        background: rgba(0, 0, 0, 0.1);
            }

    .row-portfolio .col-portfolio .btn-book-services {
        color: #fff;
        border-radius: unset;
        font-weight: bold;
    }
    
    .row-portfolio .col-portfolio .btn-view-services {
        border-radius: unset;
        font-weight: bold;
    }

    .row-portfolio .col-wedding{
        background-image: url(@Url.Content("~/resources/images/wedding.jpg"));
     }

    .row-portfolio .col-portrait{
        background-image: url(@Url.Content("~/resources/images/portrait.jpg"));
    }

    .row-portfolio .col-baptism{
        background-image: url(@Url.Content("~/resources/images/baptism.jpg"));
    }

    .row-portfolio .col-prom{
        background-image: url(@Url.Content("~/resources/images/prom.jpg"));
    }

    .row-portfolio .col-automobile{
            background-image: url(@Url.Content("~/resources/images/automobile.jpg"));
    }

    .row-portfolio .col-product{
            background-image: url(@Url.Content("~/resources/images/product.jpg"));
    }

    .row-portfolio .col-kids {
        background-image: url(@Url.Content("~/resources/images/kids.jpg"));
    }

    .row-portfolio .col-pregnancy {
        background-image: url(@Url.Content("~/resources/images/pregnancy.jpg"));
    }

    @@media only screen and (max-width: 768px){
        .icons-container .icons-column .icon-text {
            min-height: 40px;
        }

        .logo-homepage {
            width: 350px;
        }

        header.masthead{
            padding-top: 100px;
            
        }

        header.masthead .dimmer {
            
        }
    }
    @@keyframes animateMastheadTexts {
        from {
            transform: scale(.5);
        }

        to {
            transform: scale(1);
        }
    }

    @@keyframes animateBookButton{
        0% {
            transform: unset;
            box-shadow: 0px 0px 22px #ffc800;
        }

        50% {
            transform: scale(0.9);
            box-shadow: 0px 0px 8px #ffc800;
        }

        100%{
            box-shadow: 0px 0px 22px #ffc800;
        }
    }
</style>