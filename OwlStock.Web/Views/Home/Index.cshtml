@model IEnumerable<DynamicContent>

@{
    ViewData["Title"] = "Home page";
}

<!--================Banner Area =================-->
<section class="banner_area">
    <div class="booking_table d_flex align-items-center">
        <div class="overlay bg-parallax" data-stellar-ratio="0.9" data-stellar-vertical-offset="0" data-background=""></div>
        <div class="container">
            <div class="banner_content text-center">
                <h6>Фотографска агенция</h6>
                <img src="~/DreamPixW.png" class="logo-homepage" />
                <p>Нашето вдъхновение са вашите спомени</p>
                <a asp-action="Reserve" asp-controller="Photoshoot" class="btn theme_btn button_hover">Резервирай</a>
            </div>
        </div>
    </div>
    @await Component.InvokeAsync("QuickBooking")
</section>
<!--================Banner Area =================-->
<!--================ Accomodation Area  =================-->
<section class="accomodation_area section_gap">
    <div class="container">
        <div class="section_title text-center">
            <h2 class="title_color">Повече за нас</h2>
            <p>Услуги, цени, творчесто, мисия</p>
        </div>
        <div class="row mb_30">
            <div class="col-lg-3 col-sm-6">
                <div class="accomodation_item text-center">
                    <div class="hotel_img">
                        <img src="~/resources/images/services-photoshoot.jpg" alt="services-photoshoot">
                        <a asp-controller="StaticContent" asp-action="Services" class="btn theme_btn button_hover">Услуги</a>
                    </div>
                    <p class="services-subheading">Потърсете ни за всичко, което искате да се превърне в спомен</p>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="accomodation_item text-center">
                    <div class="hotel_img">
                        <img src="~/resources/images/prices-calculator.jpg" alt="">
                        <a asp-controller="StaticContent" asp-action="Pricing" class="btn theme_btn button_hover">Цени</a>
                    </div>
                    <p class="services-subheading">Разгледайте ценовата гама на предлаганите от нас услуги</p>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="accomodation_item text-center">
                    <div class="hotel_img">
                        <img src="~/resources/images/gallery-album.jpg" alt="">
                        <a asp-controller="Photo" asp-action="Index" class="btn theme_btn button_hover">Галерия</a>
                    </div>
                    <p class="services-subheading">Вдъхновете се от нашите вече направени фотографии</p>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6">
                <div class="accomodation_item text-center">
                    <div class="hotel_img">
                        <img src="~/resources/images/about-us-clones.jpg" alt="">
                        <a asp-controller="StaticContent" asp-action="About" class="btn theme_btn button_hover">За нас</a>
                    </div>
                    <p class="services-subheading">Научете повече за нашата дейност и история</p>
                </div>
            </div>
        </div>
    </div>
</section>
<section class="container">
    <div class="section_title text-center">
        <h2 class="title_color">Ще се радваме да работим заедно</h2>
        <p>Резервирайте лесно, удобно и напълно безплатно вашата следваща фотосесия</p>
    </div>
    <div class="row row-portfolio">
        <div class="col-12 col-md-6 border border-white border-5 text-center col-portfolio col-wedding">
            <div class="portfolio-content-wrap">
                <h1>Сватба</h1>
                <p>Вашата сватба през нашия обектив</p>
            </div>
            <a asp-controller="Photo" asp-action="AllByPhotoshootType" asp-route-photoshootType="@PhotoShootType.Wedding" class="btn btn-light btn-view-services">Разгледайте</a>
            <a asp-controller="PhotoShoot" asp-action="ReserveByType" asp-route-photoshootType="@PhotoShootType.Wedding" class="btn btn-warning btn-book-services">Резервирайте</a>
        </div>
        <div class="col-12 col-md-6 border border-white border-5 text-center col-portfolio col-portrait">
            <div class="portfolio-content-wrap">
                <h1>Портрет</h1>
                <p>Превърнете се в модел</p>
            </div>
            <a asp-controller="Photo" asp-action="AllByPhotoshootType" asp-route-photoshootType="@PhotoShootType.Personal" class="btn btn-light btn-view-services">Разгледайте</a>
            <a asp-controller="PhotoShoot" asp-action="ReserveByType" asp-route-photoshootType="@PhotoShootType.Personal" class="btn btn-warning btn-book-services">Резервирайте</a>
        </div>
        <div class="col-12 col-md-6 border border-white border-5 text-center col-portfolio col-baptism">
            <div class="portfolio-content-wrap">
                <h1>Свето кръщение</h1>
                <p>Ще уловим красивите и емоционални моменти от церемонията по Светото кръщение.</p>
            </div>
            <a asp-controller="Photo" asp-action="AllByPhotoshootType" asp-route-photoshootType="@PhotoShootType.Baptism" class="btn btn-light btn-view-services">Разгледайте</a>
            <a asp-controller="PhotoShoot" asp-action="ReserveByType" asp-route-photoshootType="@PhotoShootType.Baptism" class="btn btn-warning btn-book-services">Резервирайте</a>
        </div>
        <div class="col-12 col-md-6 border border-white border-5 text-center col-portfolio col-prom">
            <div class="portfolio-content-wrap">
                <h1>Абитуриентски бал</h1>
                <p>Ще създадем красиви и стилни снимки, които ще Ви напомнят за този вълнуващ момент.</p>
            </div>
            <a asp-controller="Photo" asp-action="AllByPhotoshootType" asp-route-photoshootType="@PhotoShootType.Prom" class="btn btn-light btn-view-services">Разгледайте</a>
            <a asp-controller="PhotoShoot" asp-action="ReserveByType" asp-route-photoshootType="@PhotoShootType.Prom" class="btn btn-warning btn-book-services">Резервирайте</a>
        </div>
        <div class="col-12 col-md-6 border border-white border-5 text-center col-portfolio col-automobile">
            <div class="portfolio-content-wrap">
                <h1>Автомобил</h1>
                <p>Нека автомобилът Ви бъде звездата!</p>
            </div>
            <a asp-controller="Photo" asp-action="AllByPhotoshootType" asp-route-photoshootType="@PhotoShootType.Automotive" class="btn btn-light btn-view-services">Разгледайте</a>
            <a asp-controller="PhotoShoot" asp-action="ReserveByType" asp-route-photoshootType="@PhotoShootType.Automotive" class="btn btn-warning btn-book-services">Резервирайте</a>
        </div>
        <div class="col-12 col-md-6 border border-white border-5 text-center col-portfolio col-product">
            <div class="portfolio-content-wrap">
                <h1>Продукт</h1>
                <p>Ще представим продуктовия Ви каталог в най-добра светлина.</p>
            </div>
            <a asp-controller="Photo" asp-action="AllByPhotoshootType" asp-route-photoshootType="@PhotoShootType.Product" class="btn btn-light btn-view-services">Разгледайте</a>
            <a asp-controller="PhotoShoot" asp-action="ReserveByType" asp-route-photoshootType="@PhotoShootType.Product" class="btn btn-warning btn-book-services">Резервирайте</a>
        </div>
        <div class="col-12 col-md-6 border border-white border-5 text-center col-portfolio col-pregnancy">
            <div class="portfolio-content-wrap">
                <h1>Бременност</h1>
                <p>Красотата на бремеността Ви завинаги с Вас</p>
            </div>
            <a asp-controller="Photo" asp-action="AllByPhotoshootType" asp-route-photoshootType="@PhotoShootType.Pregnant" class="btn btn-light btn-view-services">Разгледайте</a>
            <a asp-controller="PhotoShoot" asp-action="ReserveByType" asp-route-photoshootType="@PhotoShootType.Pregnant" class="btn btn-warning btn-book-services">Резервирайте</a>
        </div>
        <div class="col-12 col-md-6 border border-white border-5 text-center col-portfolio col-kids">
            <div class="portfolio-content-wrap">
                <h1>Детска фотосесия</h1>
                <p>Нека заснемем усмивките на децата Ви!</p>
            </div>
            <a asp-controller="Photo" asp-action="AllByPhotoshootType" asp-route-photoshootType="@PhotoShootType.Kids" class="btn btn-light btn-view-services">Разгледайте</a>
            <a asp-controller="PhotoShoot" asp-action="ReserveByType" asp-route-photoshootType="@PhotoShootType.Kids" class="btn btn-warning btn-book-services">Резервирайте</a>
        </div>
    </div>
</section>
<!-- Portfolio Grid-->
