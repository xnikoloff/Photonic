@model GiftCard

@{
    ViewData["Title"] = "Template";
}


<div class="certificate-wrap">
    <div class="certificate">
        <div class="header">
            <span class="small-title">Подаръчен ваучер</span>
            <h1><img src="~/img/icons/icon-1.png" alt="logo"/></h1>
        </div>
        <div class="content">
            <p class="presented">Този ваучер е създаден специално за</p>
            <div class="recipient">
                @Model.Receiver
            </div>
            <div class="details">
                <div class="item">
                    <span class="label">Фотосесия</span>
                    <span class="value">@Model.PhotoShootType</span>
                </div>
                <div class="item">
                    <span class="label">Валиден до</span>
                    <span class="value">@Model.CreatedOn.AddYears(1).ToString("dd.MM.yyyy")</span>
                </div>
            </div>
        </div>
        <div class="footer">
            <div class="signature">
                <div class="line"></div>
                <span><b>PHOTONIC.bg | +359 878 131828</b></span>
            </div>
            <div class="certificate-number">
                Certificate #PS-2026-00124
            </div>
        </div>
    </div>
</div>


<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    .certificate-wrap {
        background: #ececec;
        font-family: 'Montserrat', sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 40px;
    }

    .certificate {
        width: 1000px;
        max-width: 100%;
        box-shadow: 0 15px 40px rgba(0,0,0,.12);
        padding: 22px;
        padding: 90px 100px;
        position: relative;
        background: #dae0e3;
    }

    .header,
    .content,
    .footer {
        position: relative;
        z-index: 2;
    }

    .header {
        text-align: center;
        margin-bottom: 60px;
    }

    .small-title {
        text-transform: uppercase;
        letter-spacing: 6px;
        color: #627582;
        font-size: 13px;
    }

    .header h1 {
        font-family: "Cormorant Garamond", serif;
        font-size: 62px;
        font-weight: 600;
        color: #222;
        margin: 15px 0;
    }

    .header p {
        color: #777;
        font-size: 18px;
    }

    .presented {
        text-align: center;
        color: #777;
        letter-spacing: 1px;
        margin-bottom: 20px;
    }

    .recipient {
        text-align: center;
        font-family: "Cormorant Garamond", serif;
        font-size: 56px;
        font-weight: bold;
        color: #111;
        border-bottom: 2px solid #627582;
        display: inline-block;
        width: 100%;
        padding-bottom: 12px;
        margin-bottom: 60px;
    }

    .details {
        display: flex;
        justify-content: space-between;
        gap: 40px;
        margin-bottom: 70px;
    }

    .item {
        flex: 1;
        text-align: center;
        border: 1px solid #627582;
        border-radius: 8px;
        padding: 30px;
    }

    .label {
        display: block;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 13px;
        margin-bottom: 12px;
    }

    .value {
        font-size: 22px;
        color: #222;
        font-weight: 500;
    }

    .footer {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }

    .signature {
        width: 240px;
    }

    .line {
        height: 1px;
        background: #222;
        margin-bottom: 8px;
    }

    .signature span {
        font-size: 14px;
        color: #555;
    }

    .certificate-number {
        font-size: 13px;
        color: #888;
        letter-spacing: 2px;
    }

    @@media print {

        body {
            background: white;
            padding: 0;
        }

        .certificate {
            box-shadow: none;
            width: 100%;
        }
    }
</style>