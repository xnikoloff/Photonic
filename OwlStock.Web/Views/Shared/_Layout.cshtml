<!DOCTYPE html>
<html lang="en">

<head>

    @{
        if(Context.Request.Host.Host.ToString().Contains("test"))
        {
            <meta name="robots" content="noindex, nofollow" />
        }
    }

    <meta charset="utf-8">
    <title>@ViewData["Title"] | PHOTONIC - Нашено вдъхновение са вашите спомени</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="" name="keywords">
    <meta content="" name="description">

    <!-- Favicon -->
    <link href="~/favicon.ico" rel="icon">

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600&family=Teko:wght@400;500;600&display=swap" rel="stylesheet">

    <!-- Icon Font Stylesheet -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/magnific-popup.js/1.1.0/magnific-popup.css" />

    <!-- Libraries Stylesheet -->
    <link href="~/lib/animate/animate.min.css" rel="stylesheet">
    <link href="~/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
    <link href="~/lib/tempusdominus/css/tempusdominus-bootstrap-4.min.css" rel="stylesheet" />
    <link href="~/lib/lightbox/css/lightbox.min.css" rel="stylesheet">


    <!-- Customized Bootstrap Stylesheet -->
    <link href="~/css/bootstrap.min.css" rel="stylesheet">

    <!-- Template Stylesheet -->
    <link href="~/css/style.css" rel="stylesheet">

    <!--Selectize-->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/selectize.js/0.15.2/css/selectize.default.min.css"
          integrity="sha512-pTaEn+6gF1IeWv3W1+7X7eM60TFu/agjgoHmYhAfLEU8Phuf6JKiiE8YmsNC0aCgQv4192s4Vai8YZ6VNM6vyQ=="
          crossorigin="anonymous"
          referrerpolicy="no-referrer" />

    <!--Bootstrap-->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
</head>
<body>
    @await Component.InvokeAsync("Announcement")
    <!-- Spinner Start -->
    <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-border position-relative text-primary" style="width: 6rem; height: 6rem;" role="status"></div>
        <img class="position-absolute top-50 start-50 translate-middle" src="~/img/icons/icon-1.png" alt="Icon">
    </div>
    <!-- Spinner End -->
    <!-- Navbar Start -->
    <nav class="navbar navbar-expand-lg bg-white navbar-light sticky-top py-lg-0 px-lg-5 wow fadeIn" data-wow-delay="0.1s">
        <a asp-controller="Home" asp-action="Index" class="navbar-brand ms-4 ms-lg-0">
            <h1 class="text-primary m-0"><img class="me-3" src="~/img/icons/icon-1.png" alt="Icon">PHOTONIC</h1>
        </a>
        <button type="button" class="navbar-toggler me-4" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarCollapse">
            <div class="navbar-nav ms-auto p-4 p-lg-0">
                @if (this.User.IsInRole("Administrator"))
                {
                    <a asp-controller="Administration" asp-action="Index" class="nav-item nav-link text-info">ADMIN</a>
                }
                <a asp-controller="StaticContent" asp-action="About" class="nav-item nav-link">За нас</a>
                <a asp-controller="StaticContent" asp-action="Services" class="nav-item nav-link">Услуги</a>
                <a asp-controller="StaticContent" asp-action="Pricing" class="nav-item nav-link">Цени</a>
                
                <div class="nav-item dropdown">
                    <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Портфолио</a>
                    <div class="dropdown-menu border-0 m-0">
                        <a asp-controller="Photo" asp-action="Portfolio" asp-route-category="@Category.Wedding" class="dropdown-item">Сватба</a>
                        <a asp-controller="Photo" asp-action="Portfolio" asp-route-category="@Category.Prom" class="dropdown-item">Абитуриетски бал</a>
                        <a asp-controller="Photo" asp-action="Portfolio" asp-route-category="@Category.Baptism" class="dropdown-item">Свето кръщене</a>
                        <a asp-controller="Photo" asp-action="Portfolio" asp-route-category="@Category.Portrait" class="dropdown-item">Индивидуална фотосесия</a>
                        <a asp-controller="Photo" asp-action="Portfolio" asp-route-category="@Category.Family" class="dropdown-item">Семейна фотосесия</a>
                        <a asp-controller="Photo" asp-action="Portfolio" asp-route-category="@Category.Business" class="dropdown-item">Бизнес портрет</a>
                        <a asp-controller="Photo" asp-action="Portfolio" asp-route-category="@Category.Product" class="dropdown-item">Продукт</a>
                        <a asp-controller="Photo" asp-action="Portfolio" asp-route-category="@Category.Automotive" class="dropdown-item">Автомобил</a>
                        <a asp-controller="Photo" asp-action="Portfolio" asp-route-category="@Category.Events" class="dropdown-item">Събитие</a>
                    </div>
                </div>
                <a asp-controller="StaticContent" asp-action="Contacts" class="nav-item nav-link">Контакти</a>
                <a asp-controller="DynamicContent" asp-action="All" class="nav-item nav-link">Блог</a>
                <a asp-controller="PhotoShoot" asp-action="Reserve" class="nav-item nav-link btn btn-primary text-white px-4" style="vertical-align:central">РЕЗЕРВИРАЙ</a>
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>
    <!-- Navbar End -->

    <main id="main" role="main">
            @RenderBody()
    </main>

    <!-- Footer Start -->
    <div class="container-fluid bg-dark text-body footer mt-5 pt-5 px-0 wow fadeIn" data-wow-delay="0.1s">
        <div class="container py-5">
            <div class="row g-5">
                <div class="col-lg-3 col-md-6">
                    <h3 class="text-light mb-4">Връзка с нас</h3>
                    <!--<p class="mb-2"><i class="fa fa-map-marker-alt text-primary me-3"></i>123 Street, New York, USA</p>-->
                    <p class="mb-2 text-white"><i class="fa fa-phone-alt text-primary me-3"></i>+359878131828</p>
                    <p class="mb-2 text-white"><i class="fa fa-envelope text-primary me-3"></i>postmaster@photonic.bg</p>
                    <div class="d-flex pt-2">
                        <!--<a class="btn btn-square btn-outline-body me-1" href=""><i class="fab fa-twitter"></i></a>-->
                        <a class="btn btn-square btn-outline-body me-1" href=""><i class="fab fa-facebook-f"></i></a>
                        <a class="btn btn-square btn-outline-body me-1" href=""><i class="fab fa-youtube"></i></a>
                        <a class="btn btn-square btn-outline-body me-0" href=""><i class="fab fa-linkedin-in"></i></a>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h3 class="text-light mb-4">Услуги</h3>
                    <a class="btn btn-link" asp-controller="Photo" asp-action="Index">Портфолио</a>
                    <a class="btn btn-link" asp-controller="StaticContent" asp-action="Pricing">Цени</a>
                    <a class="btn btn-link" asp-controller="DynamicContent" asp-action="AllByPage">Блог</a>
                    <a class="btn btn-link" asp-controller="Place" asp-action="All">Локации</a>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h3 class="text-light mb-4">PHOTONIC</h3>
                    <a class="btn btn-link" asp-controller="StaticContent" asp-action="About">За нас</a>
                    <a class="btn btn-link" asp-controller="StaticContent" asp-action="Contacts">Контакти</a>
                    <a class="btn btn-link" asp-controller="StaticContent" asp-action="Services">Услуги</a>
                    <a class="btn btn-link" asp-controller="StaticContent" asp-action="FAQ">Често задавани въпроси</a>
                    <a class="btn btn-link" asp-controller="StaticContent" asp-action="TermsAndConditions">Условия за ползване</a>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h3 class="text-light mb-4">Търсене</h3>
                    <p class="text-white">Въведете ключови думи, а ние ще ви покажем красиви кадри</p>
                    <div class="position-relative mx-auto" style="max-width: 400px;">
                        <form asp-controller="Photo" asp-action="AllByTag" method="GET">
                            <input class="form-control bg-transparent w-100 py-3 ps-4 pe-5" type="text" name="tag" placeholder="котки, бал...">
                            <button type="submit" class="btn btn-primary py-2 position-absolute top-0 end-0 mt-2 me-2">Търси</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <div class="container-fluid copyright">
            <div class="container">
                <div class="row">
                    <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                        <a asp-controller="Home" asp-action="Index">PHOTONIC</a>, @DateTime.Now.Year &copy; Всички права запазени.
                    </div>
                    <div class="col-md-6 text-center text-md-end">
                        <!--/*** The author’s attribution link must remain intact in the template. ***/-->
                        <!--/*** If you wish to remove this credit link, please purchase the Buy Pro Version . ***/-->
                        Designed By <a href="https://htmlcodex.com">HTML Codex</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Footer End -->

    <!-- Back to Top -->
    <a href="#" class="btn btn-lg btn-primary btn-lg-square back-to-top"><i class="bi bi-arrow-up"></i></a>


    <!-- JavaScript Libraries -->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/wow/wow.min.js"></script>
    <script src="~/lib/easing/easing.min.js"></script>
    <script src="~/lib/waypoints/waypoints.min.js"></script>
    <script src="~/lib/counterup/counterup.min.js"></script>
    <script src="~/lib/owlcarousel/owl.carousel.min.js"></script>
    <script src="~/lib/tempusdominus/js/moment.min.js"></script>
    <script src="~/lib/tempusdominus/js/moment-timezone.min.js"></script>
    <script src="~/lib/tempusdominus/js/tempusdominus-bootstrap-4.min.js"></script>
    <script src="~/lib/lightbox/js/lightbox.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.isotope/3.0.6/isotope.pkgd.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/magnific-popup.js/1.1.0/jquery.magnific-popup.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/selectize.js/0.15.2/js/selectize.min.js"
            integrity="sha512-IOebNkvA/HZjMM7MxL0NYeLYEalloZ8ckak+NDtOViP7oiYzG5vn6WVXyrJDiJPhl4yRdmNAG49iuLmhkUdVsQ=="
            crossorigin="anonymous"
            referrerpolicy="no-referrer"></script>
    
    <!-- Template Javascript -->
    <script src="~/js/main.js"></script>


    

    <!--RichText editor-->
    <link rel="stylesheet" href="~/lib/RichText-master/src/richtext.min.css">
    <script src="~/lib/RichText-master/src/jquery.richtext.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        $(document).ready(function(){
            addEuroPrice();
        });

        function addEuroPrice() {
            const exchangeRate = 1.95583;

            let priceElement = $(".service-price");

            for (let i = 0; i < priceElement.length; i++) {
                let bgnText = priceElement[i].innerHTML;
                let bgnValue = parseFloat(bgnText.replace(" лв", ""));
                //August 2026 -> let eurValue = Math.ceil((bgnValue / exchangeRate) / 10) * 10;
                let eurValue = (bgnValue / exchangeRate).toFixed(2);
                priceElement[i].innerText = bgnText + " / " + eurValue + " €";
            }
        }
    </script>
</body>
</html>