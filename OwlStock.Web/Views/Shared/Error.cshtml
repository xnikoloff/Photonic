@model string

@{
    ViewData["Title"] = "Грешка";
}

<div class="container-xxl pb-5 container-error-message">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <i class="fa-regular fa-face-frown text-primary icon-frown"></i>
            </div>
        </div>
        <div class="row mt-5">
            <div class="col-12 text-center">
                <h2>@Model</h2>
            </div>
        </div>
    </div>
</div>

<style>
    .container-error-message .fa-face-frown{
        font-size: 6rem;
    }
</style>