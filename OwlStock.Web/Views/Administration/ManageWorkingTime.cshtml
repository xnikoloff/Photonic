@model WorkingTime

@{
    ViewData["Title"] = "Работно време";
}

<div class="container">
    <div class="row">
        <div class="col-12">
            <h1>Работно време</h1>
        </div>
    </div>
    <div class="row">
        <div class="col-12 col-md-4 mt-5">
            <form asp-action="ManageWorkingTime" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label asp-for="Start"></label>
                    <input asp-for="Start" class="form-control"/>
                </div>
                <div class="form-group mt-3">
                    <label asp-for="End"></label>
                    <input asp-for="End" class="form-control" />
                </div>
                <button type="submit" class="btn btn-primary mt-3">Запази</button>
            </form>
        </div>
    </div>
</div>