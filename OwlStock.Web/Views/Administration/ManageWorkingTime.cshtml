@model WorkingTime

@{
    ViewData["Title"] = "Работно време";
}

<div class="container">
    <div class="row">
        <div class="col-12">
            <hr />
            <h1>Работно време <span class="text-primary">@(Model.Start):00 - @(Model.End):00</span></h1>
            <hr />
        </div>
    </div>
    <div class="row">
        <div class="col-12 col-md-4 mt-5">
            <form asp-action="ManageWorkingTime" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="form-group">
                    <label asp-for="Start"></label>
                    <input asp-for="Start" class="form-control"/>
                </div>
                <div class="form-group mt-3">
                    <label asp-for="End"></label>
                    <input asp-for="End" class="form-control" />
                </div>
                <button type="submit" class="btn btn-primary mt-3">Запази</button>
            </form>
        </div>
    </div>
</div>