@model Announcement

<div class="container my-5 py-5">
    <div class="row">
        <div class="col-12">
            <h4>Create Announcement</h4>
        </div>
    </div>
    <div class="row mt-5">
        <div class="col-12">
            <form asp-action="CreateAnnouncement" asp-controller="Administration" method="POST">
                <div class="form-group">
                    <label asp-for="Content"></label>
                    <textarea asp-for="Content" class="form-control" rows="8"></textarea>
                </div>
                <button type="submit" class="btn btn-warning text-white">Create</button>
            </form>
        </div>
    </div>
</div>