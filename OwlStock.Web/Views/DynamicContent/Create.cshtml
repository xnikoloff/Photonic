@model CreateDynamicContentDTO

@{
    ViewData["Title"] = "Create";
}

<link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet">

<div class="container container-dynamic-content">
    <div class="row">
        <div class="col-12">
            <a asp-controller="DynamicContent" asp-action="CreateCategory" class="btn btn-primary mb-3">Categories</a>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <form asp-action="Create" method="POST" enctype="multipart/form-data" id="dynamicContentForm">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label asp-for="SelectedCategoryId"></label>
                    <select asp-for="SelectedCategoryId" asp-items="@(new SelectList(Model?.DynamicContentCategories, "Id", "Name"))" class="form-control"></select>
                </div>
                <div class="form-group">
                    <label asp-for="DynamicContent!.Title"></label>
                    <input asp-for="DynamicContent!.Title" class="form-control" required />
                </div>
                <div class="form-group">
                    <label asp-for="DynamicContent!.Description"></label>
                    <input asp-for="DynamicContent!.Description" class="form-control" required />
                </div>
                <div class="form-group">
                    <label asp-for="Image">Image</label>
                    <input asp-for="Image" class="form-control" required />
                </div>
                <div class="form-group">
                    <label asp-for="DynamicContent!.IsVisible"></label>
                    <input asp-for="DynamicContent!.IsVisible" />
                </div>
                <div class="form-group">
                    <label asp-for="DynamicContent!.ShowInTopPosition"></label>
                    <input asp-for="DynamicContent!.ShowInTopPosition" />
                </div>
                <input type="hidden" asp-for="DynamicContent!.Content"/>
                <div id="editor">
                    <h2>Demo Content</h2>
                    <p>Preset build with <code>snow</code> theme, and some common formats.</p>
                </div>
                <button type="submit" class="btn btn-primary mt-3">Create</button>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
<script>
    $(document).ready(function () {
        const quill = new Quill('#editor', {
            theme: 'snow'
        });

        $("#dynamicContentForm").on('submit', function (e) {
            $("#DynamicContent_Content").val(quill.root.innerHTML);
        });
    });
</script>