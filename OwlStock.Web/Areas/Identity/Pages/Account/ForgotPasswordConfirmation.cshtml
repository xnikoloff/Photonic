@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Потвърждение на забравена парола";
}

<div class="row mt-5 pt-5 mx-auto text-center">
    <div class="col-12 mx-auto my-5 text-center">
        <h1 class="text-warning">@ViewData["Title"]</h1>
        <h4 class="text-warning">Моля, проверете имейлът си и следвайте инструкците.</h4>
    </div>
</div>
<div class="row mb-5 pb-5">
    <div class="col-12 mx-auto text-center">
        <a asp-page="./Login" class="btn btn-lg btn-dark account-prompt">ВХОД</a>
    </div>
</div>
