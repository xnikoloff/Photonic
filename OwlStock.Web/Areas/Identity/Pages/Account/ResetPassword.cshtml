@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Възстановяване на парола";
}
<!-- Login Start -->
<div class="container-xxl pb-5">
    <div class="container">
        <div class="text-center mx-auto wow fadeInUp" data-wow-delay="0.1s" style="max-width: 500px;">
            <p class="text-primary text-uppercase mb-2">@ViewData["Title"]</p>
            <h1 class="display-6 mb-5">Въведете нова парола за вашият профил</h1>
        </div>
        <div class="row g-0 justify-content-center">
            <div class="col-lg-8 wow fadeInUp" data-wow-delay="0.1s">
                <p class="text-center mb-4">Въведете нова парола за профила, чиято парола се опитвате да възстановите</p>
                <div asp-validation-summary="All" class="text-danger"></div>
                <form id="account" method="post" onsubmit="onSubmit()">
                    <input asp-for="Input.Code" type="hidden" />
                    <div class="row">
                        <div class="col-12 text-center mx-auto">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-12">
                            <div class="form-floating">
                                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Email" readonly/>
                                <label asp-for="Input.Email">Имейл</label>
                                <span asp-validation-for="Input.Email" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="Input.Password" type="password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Парола" />
                                <label asp-for="Input.Password">Парола</label>
                                <span class="password-toggle-icon"><i class="fas fa-eye"></i></span>
                                <span asp-validation-for="Input.Password" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6 text-right">
                            <div class="form-floating">
                                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Повтори парола" />
                                <label asp-for="Input.ConfirmPassword">Повтори парола</label>
                                <span class="password-toggle-icon"><i class="fas fa-eye"></i></span>
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                            </div>
                        </div>

                    </div>
                    <div class="row mt-4">
                        <div class="col-12 text-center mt-3">
                            <button class="btn btn-primary py-3 px-5" type="submit">Възстанови</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<!-- Login End -->


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/custom//passwordVisibility.js"></script>
}


<style>
    .password-toggle-icon {
        position: absolute;
        top: 50%;
        right: 10px;
        transform: translateY(-50%);
        cursor: pointer;
    }

    .password-toggle-icon i {
        font-size: 18px;
        line-height: 1;
        color: #333;
        transition: color 0.3s ease-in-out;
        margin-bottom: 20px;
    }

    .password-toggle-icon i:hover {
        color: #000;
    }
</style>
