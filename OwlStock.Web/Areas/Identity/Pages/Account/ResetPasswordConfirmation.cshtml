@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Паролата Ви е възстановена";
}

<div class="container container-reset-successful">
    <div class="row">
        <div class="col-12 text-center">
            <h1>@ViewData["Title"]</h1>
            <p> Паролата Ви е възстановена. Може да влезете от <a asp-page="./Login" class="text-warning">тук</a>.</p>
        </div>
    </div>
</div>

<style>
    .container-reset-successful{
        padding-top: 200px;
        padding-bottom: 100px;
    }

    @@media only screen and (max-width: 768px) {
        .container-reset-successful .row h1 {
            font-size: 1.8rem;
        }
    }
</style>
