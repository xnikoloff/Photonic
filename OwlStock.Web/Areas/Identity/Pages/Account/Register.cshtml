@page
@model RegisterModel
@inject IConfiguration configuration
@{
    string siteKey = configuration["ReCaptcha:SiteKey"] ?? "";
    ViewData["Title"] = "Регистрация";
}


<div class="container mt-5 py-5">
    <div class="row mt-5">
        <div class="col-12 text-center">
            <h1 id="title">@ViewData["Title"]</h1>
        </div>
    </div>
    <div class="row mt-4">
        <div class="col-md-4 col-account-form">
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" onsubmit="onSubmit()">
                <input type="hidden" asp-for="ReCaptchaToken" id="recaptchaTokenInputId" />
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-floating">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Email"/>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="form-floating">
                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Парола" />
                    <button type="button" class="btn btn-light btn-password btn-password-show"><i class="fa-solid fa-eye"></i></button>
                    <button type="button" class="btn btn-light btn-password btn-password-hide" style="display:none"><i class="fa-solid fa-eye-slash"></i></button>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="form-floating">
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Потвърди парола" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>
                <div class="form-floating">
                    <div id="recaptcha-container" data-callback="recaptchaCallback"></div>
                </div>
                <button id="btn-account-submit" type="submit" class="w-100 btn btn-lg btn-warning text-white btn-account-submit" disabled>Регистрация</button>
                <div class="account-prompt-container">
                    <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-sm btn-secondary account-prompt">Вече имате акаунт?</a>
                </div>
            </form>
        </div>
    
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://www.google.com/recaptcha/api.js"></script>
    <script src="~/js/custom//recaptcha.js" data-siteKey="@siteKey"></script>
    <script src="~/js/custom//passwordVisibility.js"></script>
    <script src="https://www.google.com/recaptcha/api.js?onload=onloadCallback&render=explicit" async defer> </script>
}

<style>
    #registerForm .form-control{
        border-radius: 0 !important;
    }

    .btn-password {
        border-radius: 0 !important;
    }
</style>
