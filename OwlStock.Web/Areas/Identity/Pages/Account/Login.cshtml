@page
@model LoginModel
@inject IConfiguration configuration

@{
    string siteKey = configuration["ReCaptcha:SiteKey"] ?? "";
    ViewData["Title"] = "Вход";
}
<form id="account" method="post" onsubmit="onSubmit()">
    <input type="hidden" asp-for="ReCaptchaToken" id="recaptchaTokenInputId"/>
    <div class="hotel_booking_area position">
        <div class="container booking-container">
            <div class="row">
                <div class="col-12 text-center">
                    <h1 class="mr-lg-5">@ViewData["Title"]</h1>
                </div>
            </div>
            <div class="row">
                <div class="col-12 text-center mx-auto">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                </div>
            </div>
            <div class="hotel_booking_table">
                <div class="col-md-12">
                    <div class="boking_table">
                        <div class="row">
                            <div class="col-md-4 text-center mx-auto">
                                <div class="book_tabel_item">
                                    <div class="form-group">
                                        <div class="input-group border border-warning">
                                            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Email"/>
                                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-md-4 text-center mx-auto">
                                <div class="book_tabel_item">
                                    <div class="form-group">
                                        <div class="input-group border border-warning">
                                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Парола"/>
                                            <button type="button" class="btn btn-light btn-password btn-password-show"><i class="fa-solid fa-eye"></i></button>
                                            <button type="button" class="btn btn-light btn-password btn-password-hide" style="display:none"><i class="fa-solid fa-eye-slash"></i></button>
                                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-12 col-md-4 text-center mx-auto">
                                <div class="book_tabel_item">
                                    <div class="form-group">
                                        <div class="input-group ml-4">
                                            <label asp-for="Input.RememberMe" class="form-label">
                                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                                @Html.DisplayNameFor(m => m.Input.RememberMe)
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-12 col-md-4 text-center mx-auto">
                                <div id="recaptcha-container" data-callback="recaptchaCallback"></div>
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-12 col-md-4 text-center mx-auto">
                                <button id="btn-account-submit" type="submit" class="w-100 btn btn-lg btn-warning text-white btn-account-submit" disabled>Вход</button>
                            </div>
                        </div>
                        <div class="row mt-4">
                            <div class="col-12 col-md-4 text-center mx-auto">
                                <a id="forgot-password" asp-page="./ForgotPassword" class="btn btn-sm btn-dark account-prompt">Забравена парола?</a>
                                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-sm btn-secondary account-prompt">Нямате акаунт?</a>
                                @*<a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend email confirmation</a>*@
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://www.google.com/recaptcha/api.js"></script>
    <script src="~/js/custom//recaptcha.js" data-siteKey="@siteKey"></script>
    <script src="~/js/custom//passwordVisibility.js"></script>
    <script src="https://www.google.com/recaptcha/api.js?onload=onloadCallback&render=explicit" async defer> </script>
}

<style>
    .hotel_booking_table {
        background: none;
    }

    .booking-container{
        padding-top: 150px;
        padding-bottom: 50px;
    }

    .btn-password{
        border-radius: 0 !important;
    }
</style>
